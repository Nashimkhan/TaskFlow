@model ErrorViewModel

@{
    ViewData["Title"] = "Something went wrong";
}

<div class="page d-flex align-items-center justify-content-center">

    <div class="container"
         style="max-width:650px;min-height:70vh;display:flex;align-items:center;">

        <div class="card shadow-sm w-100">

            <div class="card-body text-center p-5">

                <div class="member-avatar mx-auto mb-4"
                     style="width:90px;height:90px;font-size:38px;background:#fee2e2;color:#dc2626;">

                    <i class="bi bi-exclamation-triangle-fill"></i>

                </div>

                <h1 class="page-title">

                    Oops!

                </h1>

                <p class="page-subtitle mb-4">

                    Something went wrong while processing your request.

                </p>

                @if (Model.ShowRequestId)
                {
                    <div class="alert alert-light">

                        <strong>Request ID</strong>

                        <br />

                        <code>@Model.RequestId</code>

                    </div>
                }

                <div class="d-flex justify-content-center gap-3 mt-4">

                    <a asp-controller="Task"
                       asp-action="Index"
                       class="btn btn-primary">

                        <i class="bi bi-house-door me-2"></i>

                        Dashboard

                    </a>

                    <button class="btn btn-light"
                            onclick="history.back()">

                        <i class="bi bi-arrow-left me-2"></i>

                        Go Back

                    </button>

                </div>

                <hr class="my-5" />

                <p class="text-muted small mb-0">

                    If this problem keeps happening,
                    please contact the administrator
                    and include the Request ID above.

                </p>

            </div>

        </div>

    </div>

</div>