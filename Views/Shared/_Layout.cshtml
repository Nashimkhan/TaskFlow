@using Microsoft.AspNetCore.Identity

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - TaskFlow</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet" />

    <link rel="preconnect"
          href="https://fonts.googleapis.com" />

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
          rel="stylesheet" />

    <link href="~/css/site.css"
          rel="stylesheet"
          asp-append-version="true" />

</head>

<body>

<header class="app-header">

<nav class="navbar navbar-expand-lg">

<div class="container">

<a asp-controller="Home"
   asp-action="Index"
   class="navbar-brand">

<i class="bi bi-check2-square-fill text-primary me-2"></i>

TaskFlow

</a>

<button class="navbar-toggler border-0 shadow-none"
        data-bs-toggle="collapse"
        data-bs-target="#navbar">

<span class="navbar-toggler-icon"></span>

</button>

<div class="collapse navbar-collapse"
     id="navbar">

@if (User.Identity?.IsAuthenticated == true)
{

<ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">

<li class="nav-item">

<a asp-controller="Task"
   asp-action="Index"
   class="nav-link">

Dashboard

</a>

</li>

<li class="nav-item">

<a asp-controller="Project"
   asp-action="Index"
   class="nav-link">

Projects

</a>

</li>

<li class="nav-item">

<a asp-controller="Task"
   asp-action="AiBreakdown"
   class="nav-link">

AI Planner

</a>

</li>

@if (User.IsInRole("Admin"))
{

<li class="nav-item">

<a asp-controller="Admin"
   asp-action="Index"
   class="nav-link">

Admin

</a>

</li>

}

<li class="nav-item dropdown ms-lg-3">

<a class="nav-link dropdown-toggle d-flex align-items-center gap-2"
   data-bs-toggle="dropdown"
   href="#">

<div class="avatar">

@(string.IsNullOrWhiteSpace(User.Identity?.Name)
    ? "?"
    : User.Identity.Name.Substring(0, 1).ToUpper())

</div>

<span>

@User.Identity?.Name

</span>

</a>

<ul class="dropdown-menu dropdown-menu-end shadow border-0">

<li>

<h6 class="dropdown-header">

Account

</h6>

</li>

<li>

<span class="dropdown-item-text">

@User.Identity?.Name

</span>

</li>

<li>

<hr class="dropdown-divider" />

</li>

<li>

<a asp-controller="Home"
   asp-action="Logout"
   class="dropdown-item text-danger">

<i class="bi bi-box-arrow-right me-2"></i>

Logout

</a>

</li>

</ul>

</li>

</ul>

}
else
{

<ul class="navbar-nav ms-auto align-items-center">

<li class="nav-item">

<a href="/#features"
   class="nav-link">

Features

</a>

</li>

<li class="nav-item">

<a href="/#about"
   class="nav-link">

About

</a>

</li>

<li class="nav-item ms-lg-3">

<a href="/#login"
   class="btn btn-primary px-4">

Get Started

</a>

</li>

</ul>

}

</div>

</div>

</nav>

</header>


<main class="page-content">

<div class="container">


@if (TempData["Success"] != null)
{

<div class="alert
            alert-success
            alert-dismissible
            fade
            show
            shadow-sm
            taskflow-auto-alert"
     role="alert">

<i class="bi bi-check-circle-fill me-2"></i>

@TempData["Success"]

<button type="button"
        class="btn-close"
        data-bs-dismiss="alert"
        aria-label="Close">
</button>

</div>

}


@if (TempData["Error"] != null)
{

<div class="alert
            alert-danger
            alert-dismissible
            fade
            show
            shadow-sm
            taskflow-auto-alert"
     role="alert">

<i class="bi bi-exclamation-circle-fill me-2"></i>

@TempData["Error"]

<button type="button"
        class="btn-close"
        data-bs-dismiss="alert"
        aria-label="Close">
</button>

</div>

}


@RenderBody()

</div>

</main>


<footer class="border-top py-4 mt-5">

<div class="container">

<div class="d-flex
            justify-content-between
            align-items-center
            flex-wrap
            gap-3">

<div class="text-muted small">

© @DateTime.Now.Year TaskFlow

</div>

<div class="text-muted small">

Built with ASP.NET Core MVC • PostgreSQL • AI

</div>

</div>

</div>

</footer>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script src="~/js/site.js"
        asp-append-version="true"></script>


<script>

    document.addEventListener(
        "DOMContentLoaded",
        function () {

            const alerts =
                document.querySelectorAll(
                    ".taskflow-auto-alert");

            alerts.forEach(function (alertElement) {

                setTimeout(function () {

                    if (!document.body.contains(
                            alertElement)) {

                        return;

                    }

                    const alert =
                        bootstrap.Alert.getOrCreateInstance(
                            alertElement);

                    alert.close();

                }, 4000);

            });

        });

</script>


@await RenderSectionAsync(
    "Scripts",
    required: false)


</body>

</html>