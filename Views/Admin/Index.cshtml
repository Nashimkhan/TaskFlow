@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager
@model List<IdentityUser>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page">

    <div class="container">

        <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div>

                <span class="badge bg-primary mb-3">

                    <i class="bi bi-shield-lock me-2"></i>

                    ADMIN

                </span>

                <h1 class="page-title">

                    Admin Dashboard

                </h1>

                <p class="page-subtitle">

                    Monitor users and manage the TaskFlow platform.

                </p>

            </div>

            <a asp-controller="Task"
               asp-action="Index"
               class="btn btn-light">

                <i class="bi bi-arrow-left me-2"></i>

                Dashboard

            </a>

        </div>

        <div class="row g-3 mb-4">

            <div class="col-md-3">

                <div class="stat-card">

                    <div class="stat-title">

                        Users

                    </div>

                    <div class="stat-value">

                        @ViewBag.TotalUsers

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-card">

                    <div class="stat-title">

                        Tasks

                    </div>

                    <div class="stat-value">

                        @ViewBag.TotalTasks

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-card">

                    <div class="stat-title">

                        Completed

                    </div>

                    <div class="stat-value text-success">

                        @ViewBag.CompletedTasks

                    </div>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-card">

                    <div class="stat-title">

                        Pending

                    </div>

                    <div class="stat-value text-warning">

                        @ViewBag.PendingTasks

                    </div>

                </div>

            </div>

        </div>

        <div class="card">

            <div class="card-header d-flex justify-content-between align-items-center">

                <h3 class="mb-0">

                    Users

                </h3>

                <span class="badge bg-light text-dark">

                    @Model.Count

                </span>

            </div>

            @if (!Model.Any())
            {

                <div class="empty-state">

                    <i class="bi bi-people"></i>

                    <h3>

                        No Users

                    </h3>

                </div>

            }
            else
            {

                <div class="table-responsive">

                    <table class="table align-middle mb-0">

                        <thead>

                            <tr>

                                <th>User</th>

                                <th>Email</th>

                                <th>ID</th>

                                <th class="text-end">

                                    Actions

                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var user in Model)
                            {
                                var isAdmin =
                                    await UserManager.IsInRoleAsync(user, "Admin");

                                <tr>

                                    <td>

                                        <div class="d-flex align-items-center gap-3">

                                            <div class="member-avatar">

                                                @(string.IsNullOrWhiteSpace(user.UserName)
                                                ? "?"
                                                : user.UserName.Substring(0, 1).ToUpper())

                                            </div>

                                            <div>

                                                <strong>

                                                    @user.UserName

                                                </strong>

                                                @if (isAdmin)
                                                {
                                                    <br />

                                                    <span class="badge bg-primary">

                                                        Admin

                                                    </span>
                                                }

                                            </div>

                                        </div>

                                    </td>

                                    <td>

                                        @(string.IsNullOrWhiteSpace(user.Email)
                                        ? "-"
                                        : user.Email)

                                    </td>

                                    <td>

                                        <small class="text-muted">

                                            @user.Id

                                        </small>

                                    </td>

                                    <td class="text-end">

                                        <div class="d-flex justify-content-end gap-2">

                                            <a asp-action="UserTasks"
                                               asp-route-id="@user.Id"
                                               class="btn btn-outline-primary btn-sm">

                                                View Tasks

                                            </a>

                                            @if (!isAdmin)
                                            {

                                                <form asp-action="DeleteUser"
                                                      method="post"
                                                      onsubmit="return confirmDeleteUser('@user.UserName');">

                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden"
                                                           name="id"
                                                           value="@user.Id" />

                                                    <button class="btn btn-outline-danger btn-sm">

                                                        Delete

                                                    </button>

                                                </form>

                                            }

                                        </div>

                                    </td>

                                </tr>

                            }

                        </tbody>

                    </table>

                </div>

            }

        </div>

    </div>

</div>

@section Scripts {

    <script>

        function confirmDeleteUser(name){

        return confirm(

        "Delete "+name+" permanently?"

        );

        }

    </script>

}