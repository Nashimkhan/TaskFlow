@{
    Layout = null;
    var showRegister = ViewBag.ShowRegister == true;
}

<!DOCTYPE html>
<html>
<head>
    <title>TaskFlow</title>

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <style>
            body {
                background: linear-gradient(135deg, #667eea, #764ba2);
                min-height: 100vh;
            }

            .auth-card {
                border-radius: 15px;
            }

            .toggle-btn {
                border-radius: 10px;
            }

            .email-info {
                font-size: 13px;
            }

            .notification {
                border: none;
                border-radius: 10px;
                font-size: 14px;
                padding: 12px 15px;
                transition: opacity 0.3s ease;
            }
    </style>
</head>

<body>

    <div class="container min-vh-100 d-flex justify-content-center align-items-center">

        <div class="card shadow-lg p-4 auth-card bg-white"
             style="width:400px;">

            <h3 class="text-center fw-bold mb-2">
                TaskFlow
            </h3>

            <p class="text-center text-muted mb-4">
                Manage your tasks smarter 🚀
            </p>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success notification d-flex align-items-center gap-2">
                    <span class="fw-bold">✓</span>
                    <span>@TempData["Success"]</span>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger notification d-flex align-items-center gap-2">
                    <span class="fw-bold">!</span>
                    <span>@TempData["Error"]</span>
                </div>
            }

            <div class="d-flex mb-4">

                <button id="loginBtn"
                        type="button"
                        class="btn @(showRegister ? "btn-light" : "btn-primary") w-50 toggle-btn"
                        onclick="showLogin()">
                    Login
                </button>

                <button id="registerBtn"
                        type="button"
                        class="btn @(showRegister ? "btn-success" : "btn-light") w-50 toggle-btn"
                        onclick="showRegister()">
                    Register
                </button>

            </div>

            <form id="loginForm"
                  method="post"
                  asp-controller="Home"
                  asp-action="Login"
                  style="display:@(showRegister ? "none" : "block");">

                @Html.AntiForgeryToken()

                <input name="username"
                       class="form-control mb-3"
                       placeholder="Username"
                       required />

                <input name="password"
                       type="password"
                       class="form-control mb-2"
                       placeholder="Password"
                       required />

                <div class="text-end mb-3">
                    <a asp-controller="Home"
                       asp-action="ForgotPassword"
                       class="text-decoration-none small">
                        Forgot Password?
                    </a>
                </div>

                <button type="submit"
                        class="btn btn-primary w-100">
                    Login
                </button>

            </form>

            <form id="registerForm"
                  method="post"
                  asp-controller="Home"
                  asp-action="Register"
                  style="display:@(showRegister ? "block" : "none");">

                @Html.AntiForgeryToken()

                <input name="username"
                       class="form-control mb-3"
                       placeholder="Choose Username"
                       minlength="3"
                       maxlength="20"
                       pattern="[A-Za-z0-9]+"
                       title="Only letters and numbers are allowed"
                       value="@ViewBag.RegisterUsername"
                       required />

                <input name="email"
                       type="email"
                       class="form-control mb-1"
                       placeholder="Enter Email"
                       value="@ViewBag.RegisterEmail"
                       required />

                <small class="text-muted email-info d-block mb-3">
                    Please use a valid email. A verification link will be sent to this address.
                </small>

                <input name="password"
                       type="password"
                       class="form-control mb-3"
                       placeholder="Create Password"
                       minlength="6"
                       required />

                <input name="confirmPassword"
                       type="password"
                       class="form-control mb-3"
                       placeholder="Confirm Password"
                       minlength="6"
                       required />

                <button type="submit"
                        class="btn btn-success w-100">
                    Create Account
                </button>

            </form>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger notification mt-3 mb-0 d-flex align-items-center gap-2">
                    <span class="fw-bold">!</span>
                    <span>@ViewBag.Error</span>
                </div>
            }

        </div>

    </div>

    <script>
            function showLogin() {
                document.getElementById("loginForm").style.display = "block";
                document.getElementById("registerForm").style.display = "none";

                document.getElementById("loginBtn").className =
                    "btn btn-primary w-50 toggle-btn";

                document.getElementById("registerBtn").className =
                    "btn btn-light w-50 toggle-btn";
            }

            function showRegister() {
                document.getElementById("loginForm").style.display = "none";
                document.getElementById("registerForm").style.display = "block";

                document.getElementById("registerBtn").className =
                    "btn btn-success w-50 toggle-btn";

                document.getElementById("loginBtn").className =
                    "btn btn-light w-50 toggle-btn";
            }

            setTimeout(() => {
                const notifications =
                    document.querySelectorAll(".notification");

                notifications.forEach(notification => {
                    notification.style.opacity = "0";

                    setTimeout(() => {
                        notification.remove();
                    }, 300);
                });

            }, 3000);
    </script>

</body>
</html>