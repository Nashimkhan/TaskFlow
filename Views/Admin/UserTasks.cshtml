@model List<TaskFlow.Models.TaskItem>

@{
    ViewData["Title"] = "User Tasks";
}

<div class="page">

    <div class="container">

        <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div>

                <span class="badge bg-primary mb-3">

                    <i class="bi bi-shield-lock me-2"></i>

                    ADMIN

                </span>

                <h1 class="page-title">

                    @ViewBag.Username's Tasks

                </h1>

                <p class="page-subtitle">

                    Review tasks created by this user.

                </p>

            </div>

            <div class="d-flex gap-2">

                <span class="badge bg-light text-dark fs-6">

                    @Model.Count Task@(Model.Count == 1 ? "" : "s")

                </span>

                <a asp-action="Index"
                   class="btn btn-light">

                    <i class="bi bi-arrow-left me-2"></i>

                    Back

                </a>

            </div>

        </div>

        @if (!Model.Any())
        {

            <div class="empty-state">

                <i class="bi bi-list-task"></i>

                <h3>

                    No Tasks

                </h3>

                <p>

                    This user has not created any tasks yet.

                </p>

            </div>

        }
        else
        {

            <div class="row g-3">

                @foreach (var task in Model)
                {

                    var overdue =
                        task.Status != "Done" &&
                        task.DueDate.Date < DateTime.UtcNow.Date;

                    var priorityClass =
                        task.Priority == "High"
                        ? "priority-high"
                        : task.Priority == "Medium"
                            ? "priority-medium"
                            : "priority-low";

                    var statusClass =
                        task.Status == "Done"
                        ? "status-done"
                        : "status-pending";

                    <div class="col-lg-4 col-md-6">

                        <div class="task-card">

                            <div class="d-flex justify-content-between mb-3">

                                <h5 class="task-title">

                                    @task.Title

                                </h5>

                                <span class="badge @statusClass">

                                    @task.Status

                                </span>

                            </div>

                            <p class="task-description">

                                @(string.IsNullOrWhiteSpace(task.Description)
                                    ? "No description."
                                    : task.Description)

                            </p>

                            <div class="d-flex gap-2 flex-wrap mb-3">

                                <span class="badge @priorityClass">

                                    @task.Priority

                                </span>

                                @if (overdue)
                                {

                                    <span class="badge bg-danger">

                                        Overdue

                                    </span>

                                }

                            </div>

                            <div class="d-flex justify-content-between align-items-center">

                                <small class="text-muted">

                                    <i class="bi bi-calendar3 me-1"></i>

                                    @task.DueDate.ToString("dd MMM yyyy")

                                </small>

                                <div class="d-flex gap-2">

                                    <a asp-action="EditTask"
                                       asp-route-id="@task.Id"
                                       class="btn btn-outline-primary btn-sm">

                                        Edit

                                    </a>

                                    <form asp-action="DeleteTask"
                                          asp-route-id="@task.Id"
                                          method="post"
                                          onsubmit="return confirmDeleteTask();">

                                        @Html.AntiForgeryToken()

                                        <button class="btn btn-outline-danger btn-sm">

                                            Delete

                                        </button>

                                    </form>

                                </div>

                            </div>

                        </div>

                    </div>

                }

            </div>

        }

    </div>

</div>

@section Scripts {

    <script>

        function confirmDeleteTask(){

        return confirm("Delete this task permanently?");

        }

    </script>

}