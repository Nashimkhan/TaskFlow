@model List<TaskFlow.Models.TaskItem>

@{
    ViewData["Title"] = "User Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="fw-bold">📋 @ViewBag.Username's Tasks</h2>

        <p class="text-muted">
            View tasks created by this user
        </p>
    </div>

    <a asp-controller="Admin"
       asp-action="Index"
       class="btn btn-outline-primary">

        ← Admin Dashboard

    </a>

</div>

@if (!Model.Any())
{
    <div class="card shadow-sm p-5 text-center">

        <h4>No Tasks Found</h4>

        <p class="text-muted">
            This user has not created any tasks.
        </p>

    </div>
}
else
{
    <div class="row">

        @foreach (var task in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card shadow-sm p-3 h-100">

                    <div class="d-flex justify-content-between">

                        <h5 class="fw-semibold">
                            @task.Title
                        </h5>

                        <span class="badge bg-@(task.Status == "Done"
                                                          ? "success"
                                                          : "warning")">

                            @task.Status

                        </span>

                    </div>

                    <p class="text-muted small mt-2">

                        @(string.IsNullOrEmpty(task.Description)
                            ? "No description"
                            : task.Description)

                    </p>

                    <div class="mt-auto">

                        <span class="badge bg-@(task.Priority == "High"
                                                          ? "danger"
                                                          : task.Priority == "Medium"
                                                              ? "info"
                                                              : "secondary")">

                            @task.Priority

                        </span>

                        <small class="text-muted ms-2">
                            📅 @task.DueDate.ToShortDateString()
                        </small>

                    </div>

                </div>

            </div>
        }

    </div>
}