@using Microsoft.AspNetCore.Identity
@model TaskFlow.Models.TaskItem

@{
    ViewData["Title"] = "Create Task";
}

<link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css"
      rel="stylesheet" />

<div class="page">

    <div class="container" style="max-width:760px;">

        <div class="page-header">

            <a asp-action="Index"
               class="btn btn-light mb-3">

                <i class="bi bi-arrow-left me-2"></i>

                Back

            </a>

            <h1 class="page-title">

                Create Task

            </h1>

            <p class="page-subtitle">

                Add a task and organize your work.

            </p>

        </div>

        <div class="card">

            <div class="card-body">

                <form asp-action="Create"
                      method="post">

                    @Html.AntiForgeryToken()

                    <input asp-for="ProjectId"
                           type="hidden" />

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3"></div>

                    <div class="mb-4">

                        <label asp-for="Title"
                               class="form-label">

                            Title

                        </label>

                        <input asp-for="Title"
                               class="form-control"
                               placeholder="Task title" />

                        <span asp-validation-for="Title"
                              class="text-danger"></span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Description"
                               class="form-label">

                            Description

                        </label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  placeholder="Task description"></textarea>

                        <span asp-validation-for="Description"
                              class="text-danger"></span>

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-4">

                            <label asp-for="Status"
                                   class="form-label">

                                Status

                            </label>

                            <select asp-for="Status"
                                    class="form-select">

                                <option value="Pending">

                                    Pending

                                </option>

                                <option value="Done">

                                    Done

                                </option>

                            </select>

                        </div>

                        <div class="col-md-6 mb-4">

                            <label asp-for="Priority"
                                   class="form-label">

                                Priority

                            </label>

                            <select asp-for="Priority"
                                    class="form-select">

                                <option value="Low">

                                    Low

                                </option>

                                <option value="Medium">

                                    Medium

                                </option>

                                <option value="High">

                                    High

                                </option>

                            </select>

                        </div>

                    </div>

                    <div class="mb-4">

                        <label asp-for="DueDate"
                               class="form-label">

                            Due Date

                        </label>

                        <input asp-for="DueDate"
                               id="datePicker"
                               class="form-control" />

                    </div>

                    @if (ViewBag.ProjectMembers != null)
                    {

                        <div class="mb-4">

                            <label class="form-label">

                                Assign To

                            </label>

                            <select asp-for="AssignedUserId"
                                    class="form-select">

                                <option value="">

                                    Unassigned

                                </option>

                                @foreach (var user in (List<IdentityUser>)ViewBag.ProjectMembers)
                                {

                                    <option value="@user.Id">

                                        @user.UserName

                                    </option>

                                }

                            </select>

                        </div>

                    }

                    <div class="d-flex justify-content-end gap-2">

                        <a asp-action="Index"
                           class="btn btn-light">

                            Cancel

                        </a>

                        <button class="btn btn-primary">

                            <i class="bi bi-plus-lg me-2"></i>

                            Create Task

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

    <script>

        flatpickr("#datePicker",{

        dateFormat:"Y-m-d",

        minDate:"today",

        disableMobile:true

        });

    </script>

}