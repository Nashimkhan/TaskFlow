@model TaskFlow.Models.TaskItem

@{
    ViewData["Title"] = "Create Task";
}

<link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css"
      rel="stylesheet" />

<style>

    .create-task-page {
        width: 100%;
        max-width: 760px;
        margin: 0 auto;
        padding: 45px 0 70px;
    }

    .task-back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 28px;
        color: #6b7280;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
    }

        .task-back-link:hover {
            color: #4f46e5;
        }

    .task-page-header {
        margin-bottom: 32px;
    }

    .task-page-title {
        margin: 0 0 10px;
        color: #111827;
        font-size: 38px;
        font-weight: 800;
        letter-spacing: -1.5px;
    }

    .task-page-subtitle {
        margin: 0;
        color: #6b7280;
        font-size: 15px;
        line-height: 1.6;
    }

    .task-form-card {
        padding: 32px;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 15px 45px rgba(17, 24, 39, .05);
    }

    .task-label {
        margin-bottom: 8px;
        color: #374151;
        font-size: 14px;
        font-weight: 600;
    }

    .task-input {
        min-height: 48px;
        color: #111827;
        background: #ffffff;
        border: 1px solid #d1d5db;
        border-radius: 10px;
    }

        .task-input:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, .1);
        }

    textarea.task-input {
        min-height: 125px;
        resize: vertical;
    }

    .field-help {
        margin-top: 7px;
        color: #9ca3af;
        font-size: 12px;
    }

    .form-divider {
        margin: 28px 0;
        border-color: #f3f4f6;
        opacity: 1;
    }

    .task-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
    }

    .cancel-btn,
    .create-btn {
        min-height: 46px;
        padding: 10px 20px;
        border-radius: 9px;
        font-size: 14px;
        font-weight: 600;
    }

    .create-btn {
        color: #ffffff;
        background: #4f46e5;
        border: 0;
    }

        .create-btn:hover {
            color: #ffffff;
            background: #4338ca;
        }

        .create-btn:disabled {
            color: #ffffff;
            background: #6366f1;
            cursor: not-allowed;
            opacity: .75;
        }

    @@media (max-width: 767px) {

        .create-task-page {
            padding: 30px 0 50px;
        }

        .task-page-title {
            font-size: 31px;
        }

        .task-form-card {
            padding: 22px;
        }

        .task-actions {
            flex-direction: column-reverse;
        }

            .task-actions .btn {
                width: 100%;
            }
    }
</style>


<div class="create-task-page">

    <a asp-controller="Task"
       asp-action="Index"
       class="task-back-link">

        <i class="bi bi-arrow-left"></i>

        Back to tasks

    </a>


    <div class="task-page-header">

        <h1 class="task-page-title">
            Create a task
        </h1>

        <p class="task-page-subtitle">

            Add a clear task, choose its priority and set a due date.

        </p>

    </div>


    <div class="task-form-card">

        <form asp-controller="Task"
              asp-action="Create"
              method="post"
              id="createTaskForm">

            @Html.AntiForgeryToken()


            <input asp-for="ProjectId"
                   type="hidden" />


            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-4">
            </div>


            <!-- TITLE -->

            <div class="mb-4">

                <label asp-for="Title"
                       class="form-label task-label">

                    Task title

                </label>


                <input asp-for="Title"
                       class="form-control task-input"
                       placeholder="Example: Review ASP.NET Core MVC" />


                <span asp-validation-for="Title"
                      class="text-danger small">
                </span>


                <div class="field-help">

                    Keep the task title short and actionable.

                </div>

            </div>


            <!-- DESCRIPTION -->

            <div class="mb-4">

                <label asp-for="Description"
                       class="form-label task-label">

                    Description

                </label>


                <textarea asp-for="Description"
                          class="form-control task-input"
                          placeholder="Add notes or context for this task..."></textarea>


                <span asp-validation-for="Description"
                      class="text-danger small">
                </span>

            </div>


            <hr class="form-divider" />


            <!-- STATUS + PRIORITY -->

            <div class="row g-4">

                <div class="col-md-6">

                    <label asp-for="Status"
                           class="form-label task-label">

                        Status

                    </label>


                    <select asp-for="Status"
                            class="form-select task-input">

                        <option value="Pending">
                            Pending
                        </option>

                        <option value="Done">
                            Done
                        </option>

                    </select>


                    <span asp-validation-for="Status"
                          class="text-danger small">
                    </span>

                </div>


                <div class="col-md-6">

                    <label asp-for="Priority"
                           class="form-label task-label">

                        Priority

                    </label>


                    <select asp-for="Priority"
                            class="form-select task-input">

                        <option value="Low">
                            Low
                        </option>

                        <option value="Medium">
                            Medium
                        </option>

                        <option value="High">
                            High
                        </option>

                    </select>


                    <span asp-validation-for="Priority"
                          class="text-danger small">
                    </span>

                </div>

            </div>


            <!-- DUE DATE -->

            <div class="mt-4">

                <label asp-for="DueDate"
                       class="form-label task-label">

                    Due date

                </label>


                <div class="input-group">

                    <span class="input-group-text bg-white border-end-0">

                        <i class="bi bi-calendar3 text-muted"></i>

                    </span>


                    <input asp-for="DueDate"
                           id="datePicker"
                           class="form-control task-input border-start-0"
                           autocomplete="off" />

                </div>


                <span asp-validation-for="DueDate"
                      class="text-danger small">
                </span>


                <div class="field-help">

                    Choose when you plan to complete this task.

                </div>

            </div>


            <hr class="form-divider" />


            <!-- ACTIONS -->

            <div class="task-actions">

                <a asp-controller="Task"
                   asp-action="Index"
                   class="btn btn-outline-secondary cancel-btn">

                    Cancel

                </a>


                <button type="submit"
                        class="btn create-btn"
                        id="createTaskButton">

                    <i class="bi bi-plus-lg me-2"
                       id="createTaskIcon"></i>

                    <span id="createTaskButtonText">
                        Create task
                    </span>

                </button>

            </div>

        </form>

    </div>

</div>


@section Scripts {

    <partial name="_ValidationScriptsPartial" />


    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>


    <script>

        document.addEventListener(
        "DOMContentLoaded",
        function () {

        flatpickr("#datePicker", {

        dateFormat: "Y-m-d",

        minDate: "today",

        disableMobile: true

        });


        const createTaskForm =
        document.getElementById(
        "createTaskForm");

        const createTaskButton =
        document.getElementById(
        "createTaskButton");

        const createTaskButtonText =
        document.getElementById(
        "createTaskButtonText");

        const createTaskIcon =
        document.getElementById(
        "createTaskIcon");


        let isSubmitting = false;


        createTaskForm.addEventListener(
        "submit",
        function (event) {

        if (isSubmitting) {

        event.preventDefault();

        return false;

        }


        if (!createTaskForm.checkValidity()) {

        return;

        }


        isSubmitting = true;


        createTaskButton.disabled = true;


        createTaskButtonText.textContent =
        "Creating...";


        createTaskIcon.className =
        "spinner-border spinner-border-sm me-2";

        });

        });

    </script>

}