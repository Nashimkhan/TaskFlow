@model List<TaskFlow.Models.TaskItem>

@{
    ViewData["Title"] = "Overview";
}

<div class="page">

    <div class="container">

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 page-header">

            <div>

                <h1 class="page-title">

                    Overview

                </h1>

                <p class="page-subtitle">

                    Stay organized and keep track of everything in one place.

                </p>

            </div>

            <div class="d-flex gap-2">

                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin"
                       asp-action="Index"
                       class="btn btn-outline-primary">

                        <i class="bi bi-shield-lock me-2"></i>

                        Admin

                    </a>
                }

                <a asp-controller="Task"
                   asp-action="AiBreakdown"
                   class="btn btn-outline-primary">

                    <i class="bi bi-stars me-2"></i>

                    AI Planner

                </a>

                <a asp-controller="Task"
                   asp-action="Create"
                   class="btn btn-primary">

                    <i class="bi bi-plus-lg me-2"></i>

                    New Task

                </a>

            </div>

        </div>

        <div class="row g-3 mb-4">

            <div class="col-6 col-lg-3">

                <div class="stat-card">

                    <div class="stat-title">

                        Total Tasks

                    </div>

                    <div class="stat-value">

                        @ViewBag.TotalTasks

                    </div>

                </div>

            </div>

            <div class="col-6 col-lg-3">

                <div class="stat-card">

                    <div class="stat-title">

                        Completed

                    </div>

                    <div class="stat-value text-success">

                        @ViewBag.CompletedTasks

                    </div>

                </div>

            </div>

            <div class="col-6 col-lg-3">

                <div class="stat-card">

                    <div class="stat-title">

                        Pending

                    </div>

                    <div class="stat-value text-warning">

                        @ViewBag.PendingTasks

                    </div>

                </div>

            </div>

            <div class="col-6 col-lg-3">

                <div class="stat-card">

                    <div class="stat-title">

                        Overdue

                    </div>

                    <div class="stat-value text-danger">

                        @ViewBag.OverdueTasks

                    </div>

                </div>

            </div>

        </div>
                <!-- FILTERS -->

        <div class="card mb-4">

            <div class="card-body">

                <form asp-action="Index"
                      method="get">

                    <div class="row g-3">

                        <div class="col-lg-5">

                            <input type="text"
                                   name="search"
                                   value="@ViewBag.Search"
                                   class="form-control"
                                   placeholder="Search tasks..." />

                        </div>

                        <div class="col-lg-2">

                            <select name="status"
                                    class="form-select">

                                <option value="">All Status</option>

                                <option value="Pending"
                                        selected="@(ViewBag.Status == "Pending")">

                                    Pending

                                </option>

                                <option value="Done"
                                        selected="@(ViewBag.Status == "Done")">

                                    Done

                                </option>

                            </select>

                        </div>

                        <div class="col-lg-2">

                            <select name="priority"
                                    class="form-select">

                                <option value="">All Priority</option>

                                <option value="Low"
                                        selected="@(ViewBag.Priority=="Low")">

                                    Low

                                </option>

                                <option value="Medium"
                                        selected="@(ViewBag.Priority=="Medium")">

                                    Medium

                                </option>

                                <option value="High"
                                        selected="@(ViewBag.Priority=="High")">

                                    High

                                </option>

                            </select>

                        </div>

                        <div class="col-lg-3 d-flex gap-2">

                            <button class="btn btn-primary flex-fill">

                                Apply

                            </button>

                            <a asp-action="Index"
                               class="btn btn-light">

                                <i class="bi bi-arrow-clockwise"></i>

                            </a>

                        </div>

                    </div>

                </form>

            </div>

        </div>

        <!-- TASKS -->

        <div class="d-flex justify-content-between align-items-center mb-3">

            <div>

                <h3 class="section-title mb-1">

                    My Tasks

                </h3>

                <small class="text-muted">

                    @ViewBag.TotalTasks task@(ViewBag.TotalTasks == 1 ? "" : "s")

                </small>

            </div>

        </div>

        @if (!Model.Any())
        {

            <div class="empty-state">

                <i class="bi bi-check2-square"></i>

                <h3>

                    No Tasks Found

                </h3>

                <p>

                    Create a task manually or let AI generate one for you.

                </p>

                <div class="mt-4 d-flex justify-content-center gap-2 flex-wrap">

                    <a asp-action="Create"
                       class="btn btn-primary">

                        Create Task

                    </a>

                    <a asp-action="AiBreakdown"
                       class="btn btn-outline-primary">

                        AI Planner

                    </a>

                </div>

            </div>

        }
        else
        {

            <div class="row g-3">
                @foreach (var task in Model)
                {
                    var isOverdue =
                        task.Status != "Done" &&
                        task.DueDate.Date < DateTime.UtcNow.Date;

                    var priorityClass =
                        task.Priority == "High"
                            ? "priority-high"
                            : task.Priority == "Medium"
                                ? "priority-medium"
                                : "priority-low";

                    var statusClass =
                        task.Status == "Done"
                            ? "status-done"
                            : "status-pending";

                    <div class="col-lg-4 col-md-6">

                        <div class="task-card">

                            <div class="d-flex justify-content-between align-items-start mb-3">

                                <div>

                                    <h5 class="task-title">

                                        @task.Title

                                    </h5>

                                    <p class="task-description mb-0">

                                        @(string.IsNullOrWhiteSpace(task.Description)
                                            ? "No description provided."
                                            : task.Description)

                                    </p>

                                </div>

                                <span class="badge @statusClass">

                                    @task.Status

                                </span>

                            </div>

                            <div class="task-meta mb-3">

                                <span class="badge @priorityClass">

                                    @task.Priority

                                </span>

                                @if (isOverdue)
                                {
                                    <span class="badge bg-danger">

                                        Overdue

                                    </span>
                                }

                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-3">

                                <small class="text-muted">

                                    <i class="bi bi-calendar3 me-1"></i>

                                    @task.DueDate.ToString("dd MMM yyyy")

                                </small>

                            </div>

                            <div class="d-flex gap-2">

                                <a asp-action="Edit"
                                   asp-route-id="@task.Id"
                                   class="btn btn-outline-primary btn-sm flex-fill">

                                    <i class="bi bi-pencil me-1"></i>

                                    Edit

                                </a>

                                <form asp-action="Delete"
                                      asp-route-id="@task.Id"
                                      method="post"
                                      class="flex-fill"
                                      onsubmit="return confirm('Delete this task?');">

                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn btn-danger btn-sm w-100">

                                        <i class="bi bi-trash me-1"></i>

                                        Delete

                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }

        @if (ViewBag.TotalPages > 1)
        {

            <nav class="mt-5">

                <ul class="pagination justify-content-center">

                    @if (ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">

                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage - 1)"
                               asp-route-search="@ViewBag.Search"
                               asp-route-status="@ViewBag.Status"
                               asp-route-priority="@ViewBag.Priority">

                                <i class="bi bi-chevron-left"></i>

                            </a>

                        </li>
                    }

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {

                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">

                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-search="@ViewBag.Search"
                               asp-route-status="@ViewBag.Status"
                               asp-route-priority="@ViewBag.Priority">

                                @i

                            </a>

                        </li>

                    }

                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {

                        <li class="page-item">

                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage + 1)"
                               asp-route-search="@ViewBag.Search"
                               asp-route-status="@ViewBag.Status"
                               asp-route-priority="@ViewBag.Priority">

                                <i class="bi bi-chevron-right"></i>

                            </a>

                        </li>

                    }

                </ul>

            </nav>

        }

    </div>

</div>