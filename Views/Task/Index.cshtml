@model List<TaskFlow.Models.TaskItem>

@{
    ViewData["Title"] = "Dashboard";
}

<!-- ✅ SUCCESS MESSAGE -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- 📊 DASHBOARD -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm p-3 text-center">
            <h6 class="text-muted">Total Tasks</h6>
            <h3 class="fw-bold">@ViewBag.TotalTasks</h3>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm p-3 text-center">
            <h6 class="text-muted">Completed</h6>
            <h3 class="fw-bold text-success">@ViewBag.CompletedTasks</h3>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm p-3 text-center">
            <h6 class="text-muted">Pending</h6>
            <h3 class="fw-bold text-warning">@ViewBag.PendingTasks</h3>
        </div>
    </div>
</div>

<!-- 🔍 SEARCH + FILTER -->
<form method="get" class="row mb-4">
    <div class="col-md-4">
        <input type="text" name="search" class="form-control" placeholder="🔍 Search tasks..." />
    </div>

    <div class="col-md-3">
        <select name="status" class="form-select">
            <option value="">All Status</option>
            <option>Pending</option>
            <option>Done</option>
        </select>
    </div>

    <div class="col-md-3">
        <select name="priority" class="form-select">
            <option value="">All Priority</option>
            <option>Low</option>
            <option>Medium</option>
            <option>High</option>
        </select>
    </div>

    <div class="col-md-2">
        <button class="btn btn-primary w-100">Apply</button>
    </div>
</form>

<!-- HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold">Dashboard</h3>
        <p class="text-muted">Manage your tasks efficiently</p>
    </div>

    <a href="/Task/Create" class="btn btn-primary">+ New Task</a>
</div>

<!-- 🧾 TASK CARDS -->
<div class="row">
    @foreach (var task in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm p-3 h-100">

                <!-- TITLE + STATUS -->
                <div class="d-flex justify-content-between">
                    <h5 class="fw-semibold">@task.Title</h5>

                    <span class="badge bg-@(task.Status == "Done" ? "success" : "warning")">
                        @task.Status
                    </span>
                </div>

                <!-- DESCRIPTION -->
                <p class="text-muted small mt-2">
                    @(string.IsNullOrEmpty(task.Description) ? "No description" : task.Description)
                </p>

                <!-- PRIORITY + DATE -->
                <div class="mt-2">
                    <span class="badge bg-@(task.Priority == "High" ? "danger" : task.Priority == "Medium" ? "info" : "secondary")">
                        @task.Priority
                    </span>

                    <small class="text-muted ms-2">
                        📅 @task.DueDate.ToShortDateString()
                    </small>
                </div>

                <!-- ACTIONS -->
                <div class="mt-3 d-flex justify-content-end gap-2">
                    <a href="/Task/Edit/@task.Id" class="btn btn-sm btn-outline-primary">Edit</a>

                    <form method="post" action="/Task/Delete/@task.Id"
                          onsubmit="return confirm('⚠️ Delete this task?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            Delete
                        </button>
                    </form>
                </div>

            </div>
        </div>
    }
</div>

<!-- ⏱ AUTO HIDE ALERT -->
<script>
    setTimeout(() => {
        const alert = document.querySelector(".alert");
        if (alert) alert.remove();
    }, 2000);
</script>