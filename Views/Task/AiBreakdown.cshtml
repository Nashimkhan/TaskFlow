@model List<TaskFlow.Models.AiSuggestedTask>

@{
    ViewData["Title"] = "AI Assistant";
}

<style>
    .ai-page {
        max-width: 1100px;
        width: calc(100% - 40px);
        margin: 0 auto;
        padding: 55px 0 80px;
    }

    .ai-header h1 {
        color: #111827;
        font-size: 42px;
        font-weight: 800;
        letter-spacing: -1.8px;
    }

    .ai-header p {
        color: #6b7280;
        font-size: 17px;
    }

    .ai-badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        margin-bottom: 18px;
        padding: 7px 12px;
        color: #4f46e5;
        background: #eef2ff;
        border-radius: 100px;
        font-size: 13px;
        font-weight: 600;
    }

    .ai-panel {
        padding: 30px;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 15px 45px rgba(0, 0, 0, .04);
    }

    .goal-label {
        color: #111827;
        font-size: 15px;
        font-weight: 600;
    }

    .goal-input {
        min-height: 150px;
        padding: 18px;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        resize: vertical;
        font-size: 16px;
        line-height: 1.6;
    }

        .goal-input:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, .1);
        }

    .character-info {
        color: #9ca3af;
        font-size: 12px;
    }

    .generate-btn {
        min-height: 50px;
        padding: 12px 22px;
        color: #ffffff;
        background: #111827;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        transition: .25s;
    }

        .generate-btn:hover {
            color: #ffffff;
            background: #4f46e5;
            transform: translateY(-1px);
        }

        .generate-btn:disabled {
            color: #ffffff;
            background: #4f46e5;
            opacity: 1;
        }

    .suggestions-header {
        margin-top: 55px;
        margin-bottom: 25px;
    }

        .suggestions-header h3 {
            color: #111827;
            font-weight: 800;
            letter-spacing: -.7px;
        }

        .suggestions-header p {
            color: #6b7280;
            margin: 0;
        }

    .ai-task-card {
        position: relative;
        padding: 24px;
        margin-bottom: 15px;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        cursor: pointer;
        transition: .25s;
    }

        .ai-task-card:hover {
            border-color: #c7d2fe;
            box-shadow: 0 12px 35px rgba(0, 0, 0, .05);
            transform: translateY(-2px);
        }

        .ai-task-card.selected {
            border-color: #818cf8;
            background: #fafaff;
        }

    .task-checkbox {
        width: 19px;
        height: 19px;
        margin-top: 3px;
        cursor: pointer;
    }

    .suggested-title {
        color: #111827;
        font-size: 18px;
        font-weight: 700;
    }

    .suggested-description {
        margin: 10px 0 16px;
        color: #6b7280;
        font-size: 14px;
        line-height: 1.7;
    }

    .priority-pill,
    .info-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 10px;
        border-radius: 100px;
        font-size: 12px;
        font-weight: 600;
    }

    .priority-high {
        color: #b91c1c;
        background: #fef2f2;
    }

    .priority-medium {
        color: #b45309;
        background: #fffbeb;
    }

    .priority-low {
        color: #4b5563;
        background: #f3f4f6;
    }

    .info-pill {
        color: #4b5563;
        background: #f3f4f6;
    }

    .add-tasks-panel {
        position: sticky;
        bottom: 20px;
        z-index: 10;
        margin-top: 25px;
        padding: 16px;
        background: rgba(255, 255, 255, .92);
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        backdrop-filter: blur(15px);
        box-shadow: 0 15px 45px rgba(0, 0, 0, .1);
    }

    .add-tasks-btn {
        min-height: 50px;
        color: #ffffff;
        background: #111827;
        border: none;
        border-radius: 10px;
        font-weight: 600;
    }

        .add-tasks-btn:hover {
            color: #ffffff;
            background: #4f46e5;
        }

    .ai-error {
        padding: 16px 18px;
        margin-top: 25px;
        color: #b91c1c;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 12px;
    }

    .thinking-box {
        display: none;
        margin-top: 20px;
        padding: 18px;
        color: #4f46e5;
        background: #eef2ff;
        border-radius: 12px;
    }

    .thinking-dots span {
        display: inline-block;
        width: 6px;
        height: 6px;
        margin: 0 2px;
        background: #6366f1;
        border-radius: 50%;
        animation: aiThinking 1.4s infinite ease-in-out;
    }

        .thinking-dots span:nth-child(2) {
            animation-delay: .2s;
        }

        .thinking-dots span:nth-child(3) {
            animation-delay: .4s;
        }

    @@keyframes aiThinking {
        0%, 80%, 100% {
            transform: scale(.6);
            opacity: .4;
        }

        40% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@media(max-width: 767px) {
        .ai-page {
            width: calc(100% - 24px);
            padding-top: 35px;
        }

        .ai-header h1 {
            font-size: 34px;
        }

        .ai-panel {
            padding: 20px;
        }

        .ai-task-card {
            padding: 18px;
        }
    }
</style>

<div class="ai-page">

    <!-- HEADER -->

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-5">

        <div class="ai-header">

            <div class="ai-badge">
                <i class="bi bi-stars"></i>
                TASKFLOW AI
            </div>

            <h1>
                Turn goals into action.
            </h1>

            <p class="mb-0">
                Describe what you want to achieve. AI will create a practical roadmap.
            </p>

        </div>

        <a asp-action="Index"
           class="btn btn-outline-dark">

            <i class="bi bi-arrow-left me-2"></i>
            Dashboard

        </a>

    </div>


    <!-- AI INPUT -->

    <div class="ai-panel">

        <form asp-action="AiBreakdown"
              method="post"
              id="aiForm">

            @Html.AntiForgeryToken()

            <label class="goal-label mb-2">
                What do you want to achieve?
            </label>

            <textarea class="form-control goal-input"
                      name="goal"
                      id="goalInput"
                      maxlength="500"
                      required
                      placeholder="Example: Prepare for my .NET Developer interview">@ViewBag.Goal</textarea>

            <div class="d-flex justify-content-between mt-2">

                <span class="character-info">
                    Be specific for better AI suggestions.
                </span>

                <span class="character-info">
                    <span id="characterCount">0</span>/500
                </span>

            </div>

            <button type="submit"
                    id="generateBtn"
                    class="generate-btn w-100 mt-4">

                <i class="bi bi-stars me-2"></i>
                Generate action plan

            </button>

            <div id="thinkingBox"
                 class="thinking-box">

                <div class="d-flex align-items-center gap-3">

                    <i class="bi bi-stars fs-4"></i>

                    <div>

                        <div class="fw-semibold">
                            TaskFlow AI is building your roadmap
                        </div>

                        <small>
                            Analyzing your goal and creating actionable tasks
                        </small>

                    </div>

                    <div class="thinking-dots ms-auto">

                        <span></span>
                        <span></span>
                        <span></span>

                    </div>

                </div>

            </div>

        </form>

    </div>


    <!-- ERROR -->
    @if (ViewBag.Error != null)
    {
        <div class="ai-error">

            <i class="bi bi-exclamation-circle me-2"></i>

            @ViewBag.Error

        </div>
    }


    <!-- AI RESULTS -->
    @if (Model != null && Model.Any())
    {
        <form asp-action="AddAiTasks"
              method="post"
              id="addTasksForm">

            @Html.AntiForgeryToken()

            <div class="suggestions-header">

                <div class="d-flex flex-wrap justify-content-between align-items-end gap-3">

                    <div>

                        <h3>
                            Your AI roadmap
                        </h3>

                        <p>
                            Select the tasks you want to add to your dashboard.
                        </p>

                    </div>

                    <small class="text-muted">

                        <span id="selectedCount">
                            @Model.Count
                        </span>

                        of @Model.Count selected

                    </small>

                </div>

            </div>

            @for (int i = 0; i < Model.Count; i++)
            {
                var priorityClass =
                    Model[i].Priority == "High"
                        ? "priority-high"
                        : Model[i].Priority == "Medium"
                            ? "priority-medium"
                            : "priority-low";

                <div class="ai-task-card selected"
                     onclick="toggleTaskCard(this, @i)">

                    <div class="d-flex gap-3">

                        <input class="form-check-input task-checkbox"
                               type="checkbox"
                               checked
                               name="selectedTasks"
                               value="@i"
                               id="taskCheck-@i"
                               onclick="event.stopPropagation(); updateCardFromCheckbox(@i);" />

                        <div class="flex-grow-1">

                            <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">

                                <h5 class="suggested-title mb-0">
                                    @Model[i].Title
                                </h5>

                                <span class="priority-pill @priorityClass">

                                    <i class="bi bi-flag"></i>

                                    @Model[i].Priority

                                </span>

                            </div>

                            <p class="suggested-description">
                                @Model[i].Description
                            </p>

                            <div class="d-flex flex-wrap gap-2">

                                <span class="info-pill">

                                    <i class="bi bi-clock"></i>

                                    @Model[i].EstimatedDays
                                    day@(Model[i].EstimatedDays > 1 ? "s" : "")

                                </span>

                                <span class="info-pill">

                                    <i class="bi bi-calendar3"></i>

                                    @Model[i].SuggestedDueDate.ToString("dd MMM yyyy")

                                </span>

                            </div>

                        </div>

                    </div>

                    <input type="hidden"
                           name="tasks[@i].Title"
                           value="@Model[i].Title" />

                    <input type="hidden"
                           name="tasks[@i].Description"
                           value="@Model[i].Description" />

                    <input type="hidden"
                           name="tasks[@i].Priority"
                           value="@Model[i].Priority" />

                </div>
            }


            <!-- ADD TASKS -->

            <div class="add-tasks-panel">

                <div class="d-flex flex-wrap align-items-center gap-3">

                    <div class="flex-grow-1">

                        <strong>
                            Ready to add your roadmap?
                        </strong>

                        <div class="text-muted small">
                            Selected tasks will be added to your dashboard.
                        </div>

                    </div>

                    <button type="submit"
                            id="addTasksBtn"
                            class="add-tasks-btn px-4">

                        <i class="bi bi-plus-lg me-2"></i>

                        Add selected tasks

                    </button>

                </div>

            </div>

        </form>
    }

</div>

@section Scripts
{
    <script>

        const goalInput =
            document.getElementById("goalInput");

        const characterCount =
            document.getElementById("characterCount");

        function updateCharacterCount() {

            characterCount.textContent =
                goalInput.value.length;

        }

        updateCharacterCount();

        goalInput.addEventListener(
            "input",
            updateCharacterCount
        );


        document.getElementById("aiForm")
            .addEventListener("submit", function () {

                const btn =
                    document.getElementById("generateBtn");

                const thinkingBox =
                    document.getElementById("thinkingBox");

                btn.disabled = true;

                btn.innerHTML = `
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    Generating your roadmap...
                `;

                thinkingBox.style.display = "block";

            });


        function toggleTaskCard(card, index) {

            const checkbox =
                document.getElementById(
                    "taskCheck-" + index
                );

            checkbox.checked =
                !checkbox.checked;

            updateCardFromCheckbox(index);

        }


        function updateCardFromCheckbox(index) {

            const checkbox =
                document.getElementById(
                    "taskCheck-" + index
                );

            const card =
                checkbox.closest(".ai-task-card");

            if (checkbox.checked) {

                card.classList.add("selected");

            }
            else {

                card.classList.remove("selected");

            }

            updateSelectedCount();

        }


        function updateSelectedCount() {

            const checked =
                document.querySelectorAll(
                    ".task-checkbox:checked"
                ).length;

            const selectedCount =
                document.getElementById(
                    "selectedCount"
                );

            const addTasksBtn =
                document.getElementById(
                    "addTasksBtn"
                );

            if (selectedCount) {

                selectedCount.textContent =
                    checked;

            }

            if (addTasksBtn) {

                addTasksBtn.disabled =
                    checked === 0;

            }

        }

    </script>
}