@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>Forgot Password - TaskFlow</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

</head>

<body class="bg-light">

    <div class="page d-flex align-items-center justify-content-center min-vh-100">

        <div class="container" style="max-width:460px;">

            <div class="text-center mb-5">

                <a asp-action="Index"
                   class="text-decoration-none">

                    <h2 class="fw-bold text-dark">

                        TaskFlow

                    </h2>

                </a>

                <div class="member-avatar mx-auto mb-4"
                     style="width:70px;height:70px;font-size:28px;">

                    <i class="bi bi-key"></i>

                </div>

                <h1 class="page-title">

                    Forgot Password

                </h1>

                <p class="page-subtitle">

                    Enter your email address and we'll send you a password reset link.

                </p>

            </div>

            <div class="card">

                <div class="card-body">

                    <form asp-action="ForgotPassword"
                          method="post"
                          id="forgotPasswordForm">

                        @Html.AntiForgeryToken()

                        <div class="mb-4">

                            <label class="form-label">

                                Email Address

                            </label>

                            <input type="email"
                                   name="email"
                                   class="form-control"
                                   placeholder="you@example.com"
                                   required />

                        </div>

                        <button id="resetBtn"
                                class="btn btn-primary w-100">

                            <i class="bi bi-send me-2"></i>

                            Send Reset Link

                        </button>

                    </form>

                    @if (ViewBag.Error != null)
                    {

                        <div class="alert alert-danger mt-3">

                            <i class="bi bi-exclamation-circle me-2"></i>

                            @ViewBag.Error

                        </div>

                    }

                </div>

            </div>

            <div class="text-center mt-4">

                <a asp-action="Index"
                   class="btn btn-light">

                    <i class="bi bi-arrow-left me-2"></i>

                    Back to Login

                </a>

            </div>

            <p class="text-center text-muted small mt-4">

                <i class="bi bi-shield-check me-1"></i>

                Secure password recovery powered by TaskFlow

            </p>

        </div>

    </div>

    <script>

            document
            .getElementById("forgotPasswordForm")
            .addEventListener("submit",function(){

            let btn=document.getElementById("resetBtn");

            btn.disabled=true;

            btn.innerHTML=
            '<span class="spinner-border spinner-border-sm me-2"></span>Sending...';

            });

    </script>

</body>

</html>