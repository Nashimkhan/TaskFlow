@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <title>Forgot Password - TaskFlow</title>

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                min-height: 100vh;
                background: radial-gradient(circle at 80% 20%, rgba(79, 70, 229, .10), transparent 35%), radial-gradient(circle at 20% 80%, rgba(124, 58, 237, .07), transparent 35%), #ffffff;
                color: #111827;
            }

            .auth-page {
                width: 100%;
                min-height: 100vh;
                padding: 40px 20px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .auth-wrapper {
                width: 100%;
                max-width: 460px;
            }

            .brand {
                display: block;
                margin-bottom: 45px;
                color: #111827;
                font-size: 24px;
                font-weight: 800;
                text-align: center;
                text-decoration: none;
                letter-spacing: -1px;
            }

            .icon-box {
                width: 58px;
                height: 58px;
                margin: 0 auto 24px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #4f46e5;
                background: #eef2ff;
                border-radius: 15px;
                font-size: 25px;
            }

            .auth-header {
                margin-bottom: 32px;
                text-align: center;
            }

                .auth-header h1 {
                    margin-bottom: 12px;
                    font-size: 34px;
                    font-weight: 800;
                    letter-spacing: -1.3px;
                }

                .auth-header p {
                    margin: 0;
                    color: #6b7280;
                    line-height: 1.7;
                }

            .auth-card {
                padding: 32px;
                background: #ffffff;
                border: 1px solid #e5e7eb;
                border-radius: 16px;
                box-shadow: 0 20px 60px rgba(0, 0, 0, .06);
            }

            .field-label {
                margin-bottom: 8px;
                font-size: 14px;
                font-weight: 600;
            }

            .email-input {
                min-height: 50px;
                padding: 12px 15px;
                border: 1px solid #e5e7eb;
                border-radius: 10px;
            }

                .email-input:focus {
                    border-color: #6366f1;
                    box-shadow: 0 0 0 4px rgba(99, 102, 241, .1);
                }

            .reset-btn {
                min-height: 50px;
                color: #ffffff;
                background: #111827;
                border: none;
                border-radius: 10px;
                font-weight: 600;
                transition: .25s;
            }

                .reset-btn:hover {
                    color: #ffffff;
                    background: #4f46e5;
                    transform: translateY(-1px);
                }

                .reset-btn:disabled {
                    color: #ffffff;
                    background: #4f46e5;
                }

            .error-message {
                margin-top: 20px;
                padding: 14px 16px;
                color: #b91c1c;
                background: #fef2f2;
                border: 1px solid #fecaca;
                border-radius: 10px;
                font-size: 14px;
            }

            .back-link {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                margin-top: 28px;
                color: #6b7280;
                font-size: 14px;
                font-weight: 600;
                text-decoration: none;
            }

                .back-link:hover {
                    color: #111827;
                }

            .security-info {
                margin-top: 24px;
                color: #9ca3af;
                font-size: 12px;
                text-align: center;
            }

            @@media(max-width: 576px) {

                .auth-page {
                    padding: 30px 15px;
                }

                .brand {
                    margin-bottom: 35px;
                }

                .auth-header h1 {
                    font-size: 29px;
                }

                .auth-card {
                    padding: 24px;
                }
            }

    </style>

</head>

<body>

    <main class="auth-page">

        <div class="auth-wrapper">

            <a asp-controller="Home"
               asp-action="Index"
               class="brand">

                TaskFlow

            </a>


            <div class="auth-header">

                <div class="icon-box">

                    <i class="bi bi-key"></i>

                </div>

                <h1>
                    Forgot your password?
                </h1>

                <p>
                    No worries. Enter your registered email and
                    we'll send you a password reset link.
                </p>

            </div>


            <div class="auth-card">

                <form method="post"
                      asp-controller="Home"
                      asp-action="ForgotPassword"
                      id="forgotPasswordForm">

                    @Html.AntiForgeryToken()


                    <div class="mb-4">

                        <label class="field-label"
                               for="email">

                            Email address

                        </label>

                        <input id="email"
                               name="email"
                               type="email"
                               class="form-control email-input"
                               placeholder="you@example.com"
                               autocomplete="email"
                               required />

                    </div>


                    <button type="submit"
                            id="resetBtn"
                            class="btn reset-btn w-100">

                        <i class="bi bi-send me-2"></i>

                        Send reset link

                    </button>

                </form>


                @if (ViewBag.Error != null)
                {
                    <div class="error-message">

                        <i class="bi bi-exclamation-circle me-2"></i>

                        @ViewBag.Error

                    </div>
                }

            </div>


            <div class="text-center">

                <a asp-controller="Home"
                   asp-action="Index"
                   class="back-link">

                    <i class="bi bi-arrow-left"></i>

                    Back to login

                </a>

            </div>


            <div class="security-info">

                <i class="bi bi-shield-check me-1"></i>

                Secure password recovery powered by TaskFlow

            </div>

        </div>

    </main>


    <script>

            document.getElementById("forgotPasswordForm")
                .addEventListener("submit", function () {

                    const button =
                        document.getElementById("resetBtn");

                    button.disabled = true;

                    button.innerHTML = `
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        Sending reset link...
                    `;

                });

    </script>

</body>

</html>