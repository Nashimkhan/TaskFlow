@{
    Layout = null;

    var email = ViewBag.Email as string;
    var username = ViewBag.Username as string;
}

<!DOCTYPE html>
<html>
<head>
    <title>Verify Your Email - TaskFlow</title>

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <style>
            body {
                background: linear-gradient(135deg, #667eea, #764ba2);
                min-height: 100vh;
            }

            .verify-card {
                width: 430px;
                border: none;
                border-radius: 18px;
            }

            .email-icon {
                width: 75px;
                height: 75px;
                border-radius: 50%;
                background: #eef2ff;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 35px;
                margin: auto;
            }

            .email-address {
                background: #f8f9fa;
                border-radius: 10px;
                padding: 12px;
                font-weight: 600;
                word-break: break-word;
            }

            .waiting-text {
                font-size: 13px;
            }
    </style>
</head>

<body>

    <div class="container min-vh-100 d-flex justify-content-center align-items-center">

        <div class="card shadow-lg p-4 verify-card bg-white text-center">

            <div class="email-icon mb-3">
                📩
            </div>

            <h3 class="fw-bold">
                Verify Your Email
            </h3>

            <p class="text-muted mt-2">
                You're almost there, @username!
            </p>

            <p class="mb-2">
                We've sent a verification link to:
            </p>

            <div class="email-address mb-3">
                @email
            </div>

            <p class="text-muted small">
                Open your email and click the verification link
                to activate your TaskFlow account.
            </p>

            <div class="alert alert-warning small mb-3">
                🔒 Your account is not active yet.
                Verify your email before logging in.
            </div>

            <div class="spinner-border spinner-border-sm text-primary"
                 role="status">
            </div>

            <p class="text-muted waiting-text mt-2 mb-0">
                Waiting for email verification...
            </p>

            <p class="text-muted small mt-3 mb-0">
                Can't find the email? Check your spam or junk folder.
            </p>

        </div>

    </div>

</body>
</html>