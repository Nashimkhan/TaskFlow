@{
    Layout = null;

    var email = ViewBag.Email as string;
    var username = ViewBag.Username as string;
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <title>Verify Your Email - TaskFlow</title>

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                min-height: 100vh;
                color: #111827;
                background: radial-gradient(circle at 80% 20%, rgba(79, 70, 229, .10), transparent 35%), radial-gradient(circle at 20% 80%, rgba(124, 58, 237, .07), transparent 35%), #ffffff;
            }

            .verify-page {
                width: 100%;
                min-height: 100vh;
                padding: 40px 20px;
                display: flex;
                justify-content: center;
                align-items: center;
            }

            .verify-wrapper {
                width: 100%;
                max-width: 500px;
            }

            .brand {
                display: block;
                margin-bottom: 42px;
                color: #111827;
                font-size: 24px;
                font-weight: 800;
                text-align: center;
                text-decoration: none;
                letter-spacing: -1px;
            }

            .verify-card {
                padding: 38px;
                background: #ffffff;
                border: 1px solid #e5e7eb;
                border-radius: 18px;
                box-shadow: 0 20px 60px rgba(0, 0, 0, .06);
                text-align: center;
            }

            .email-icon {
                width: 68px;
                height: 68px;
                margin: 0 auto 25px;
                display: flex;
                justify-content: center;
                align-items: center;
                color: #4f46e5;
                background: #eef2ff;
                border-radius: 17px;
                font-size: 28px;
            }

            .verify-title {
                margin-bottom: 10px;
                color: #111827;
                font-size: 32px;
                font-weight: 800;
                letter-spacing: -1px;
            }

            .welcome-text {
                margin-bottom: 28px;
                color: #6b7280;
            }

            .email-label {
                margin-bottom: 10px;
                color: #6b7280;
                font-size: 14px;
            }

            .email-address {
                padding: 14px 18px;
                margin-bottom: 22px;
                color: #4338ca;
                background: #f5f3ff;
                border: 1px solid #ddd6fe;
                border-radius: 10px;
                font-size: 14px;
                font-weight: 600;
                word-break: break-word;
            }

            .instruction-text {
                margin-bottom: 25px;
                color: #6b7280;
                font-size: 14px;
                line-height: 1.7;
            }

            .account-warning {
                padding: 14px 16px;
                margin-bottom: 25px;
                color: #92400e;
                background: #fffbeb;
                border: 1px solid #fde68a;
                border-radius: 10px;
                font-size: 13px;
                text-align: left;
            }

            .waiting-section {
                padding: 20px;
                background: #f9fafb;
                border-radius: 12px;
            }

            .waiting-spinner {
                width: 22px;
                height: 22px;
                color: #4f46e5;
            }

            .waiting-text {
                margin: 10px 0 0;
                color: #6b7280;
                font-size: 13px;
            }

            .success-box {
                padding: 16px;
                color: #047857;
                background: #ecfdf5;
                border: 1px solid #a7f3d0;
                border-radius: 10px;
                font-size: 14px;
                font-weight: 600;
            }

            .help-text {
                margin: 24px 0 0;
                color: #9ca3af;
                font-size: 12px;
                line-height: 1.6;
            }

            .security-text {
                margin-top: 25px;
                color: #9ca3af;
                font-size: 12px;
                text-align: center;
            }

            @@media(max-width: 576px) {

                .verify-page {
                    padding: 30px 15px;
                }

                .brand {
                    margin-bottom: 32px;
                }

                .verify-card {
                    padding: 27px 22px;
                }

                .verify-title {
                    font-size: 28px;
                }
            }

    </style>

</head>

<body>

    <main class="verify-page">

        <div class="verify-wrapper">

            <a asp-controller="Home"
               asp-action="Index"
               class="brand">

                TaskFlow

            </a>


            <div class="verify-card">

                <div class="email-icon">

                    <i class="bi bi-envelope-check"></i>

                </div>


                <h1 class="verify-title">

                    Check your inbox.

                </h1>


                <p class="welcome-text">

                    You're almost there@(string.IsNullOrWhiteSpace(username) ? "" : $", {username}")!

                </p>


                <p class="email-label">

                    We sent a verification link to

                </p>


                <div class="email-address">

                    @email

                </div>


                <p class="instruction-text">

                    Open the email and click the verification link
                    to activate your TaskFlow account.

                </p>


                <div class="account-warning">

                    <i class="bi bi-lock me-2"></i>

                    <strong>Account not active yet.</strong>

                    Verify your email before signing in.

                </div>


                <div id="waitingSection"
                     class="waiting-section">

                    <div class="spinner-border waiting-spinner"
                         role="status">

                        <span class="visually-hidden">
                            Checking verification
                        </span>

                    </div>

                    <p class="waiting-text">

                        Waiting for email verification...

                    </p>

                </div>


                <p class="help-text">

                    <i class="bi bi-info-circle me-1"></i>

                    Can't find the email?
                    Check your spam or junk folder.

                </p>

            </div>


            <div class="security-text">

                <i class="bi bi-shield-check me-1"></i>

                Secure account verification powered by TaskFlow

            </div>

        </div>

    </main>


    <script>

            const email = @Html.Raw(
                            System.Text.Json.JsonSerializer.Serialize(email)
                    );

            let verificationInterval;


            const checkVerification = async () => {

                if (!email) {
                    return;
                }

                try {

                    const response = await fetch(
                        `/Home/CheckEmailVerification?email=${encodeURIComponent(email)}`,
                        {
                            cache: "no-store"
                        }
                    );

                    if (!response.ok) {
                        return;
                    }

                    const data =
                        await response.json();


                    if (data.verified === true) {

                        clearInterval(
                            verificationInterval
                        );


                        document.getElementById(
                            "waitingSection"
                        ).innerHTML = `

                            <div class="success-box">

                                <i class="bi bi-check-circle-fill me-2"></i>

                                Email verified successfully!

                                <div class="mt-1 fw-normal">

                                    Redirecting you to login...

                                </div>

                            </div>

                        `;


                        setTimeout(() => {

                            window.location.href = "/#login";

                        }, 1500);

                    }

                }
                catch (error) {

                    console.log(
                        "Waiting for email verification..."
                    );

                }

            };


            checkVerification();


            verificationInterval = setInterval(

                checkVerification,

                2000

            );

    </script>

</body>

</html>