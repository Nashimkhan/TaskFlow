@{
    Layout = null;

    var email = ViewBag.Email as string;
    var username = ViewBag.Username as string;
}

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>Verify Email - TaskFlow</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

</head>

<body class="bg-light">

    <div class="page d-flex align-items-center justify-content-center min-vh-100">

        <div class="container"
             style="max-width:520px;">

            <div class="text-center mb-5">

                <a asp-action="Index"
                   class="text-decoration-none">

                    <h2 class="fw-bold text-dark">

                        TaskFlow

                    </h2>

                </a>

                <div class="member-avatar mx-auto mb-4"
                     style="width:75px;height:75px;font-size:30px;">

                    <i class="bi bi-envelope-check"></i>

                </div>

                <h1 class="page-title">

                    Verify Your Email

                </h1>

                <p class="page-subtitle">

                    @(string.IsNullOrWhiteSpace(username)
                    ? "Almost there!"
                    : $"Almost there, {username}!")

                </p>

            </div>

            <div class="card">

                <div class="card-body text-center">

                    <p class="text-muted">

                        We've sent a verification link to

                    </p>

                    <div class="alert alert-primary fw-semibold">

                        @email

                    </div>

                    <p class="text-muted mb-4">

                        Click the link in your inbox to activate your TaskFlow account.

                    </p>

                    <div class="alert alert-warning">

                        <i class="bi bi-lock me-2"></i>

                        Your account cannot be used until your email is verified.

                    </div>

                    <div id="waitingSection">

                        <div class="spinner-border text-primary mb-3"></div>

                        <p class="text-muted">

                            Waiting for email verification...

                        </p>

                    </div>

                    <div class="small text-muted mt-4">

                        <i class="bi bi-info-circle me-1"></i>

                        Can't find the email? Check your Spam or Junk folder.

                    </div>

                </div>

            </div>

            <p class="text-center text-muted small mt-4">

                <i class="bi bi-shield-check me-1"></i>

                Secure email verification powered by TaskFlow

            </p>

        </div>

    </div>

    <script>

            const email=@Html.Raw(
                    System.Text.Json.JsonSerializer.Serialize(email));

            let interval;

            async function checkVerification(){

            if(!email)return;

            try{

            const response=await fetch(

            `/Home/CheckEmailVerification?email=${encodeURIComponent(email)}`,

            {cache:"no-store"}

            );

            if(!response.ok)return;

            const data=await response.json();

            if(data.verified){

            clearInterval(interval);

            document.getElementById("waitingSection").innerHTML=`

            <div class="alert alert-success mb-0">

            <i class="bi bi-check-circle-fill me-2"></i>

            Email verified successfully.<br>

            Redirecting to login...

            </div>`;

            setTimeout(()=>{

            window.location.href="/#login";

            },1500);

            }

            }
            catch{}

            }

            checkVerification();

            interval=setInterval(checkVerification,2000);

    </script>

</body>

</html>