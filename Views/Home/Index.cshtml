@{
    ViewData["Title"] = "TaskFlow";

    var showRegister = ViewBag.ShowRegister == true;
}

<div class="landing-page">

    <div class="container-fluid vh-100">

        <div class="row h-100">

            <!-- LEFT SIDE -->

            <div class="col-lg-6 d-flex align-items-center">

                <div class="mx-auto"
                     style="max-width:520px;">

                    <a asp-action="Index"
                       class="text-decoration-none">

                        <h2 class="fw-bold mb-5">

                            <i class="bi bi-check2-square text-primary me-2"></i>

                            TaskFlow

                        </h2>

                    </a>

                    <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2 mb-4">

                        AI Powered Productivity

                    </span>

                    <h1 class="display-3 fw-bold lh-sm">

                        Plan.

                        <br>

                        Build.

                        <br>

                        <span class="text-primary">

                            Deliver.

                        </span>

                    </h1>

                    <p class="lead text-muted mt-4">

                        AI task planning,

                        team collaboration,

                        project tracking.

                    </p>

                    <div class="d-flex gap-3 mt-5">

                        <div class="card border-0 shadow-sm">

                            <div class="card-body text-center px-4">

                                <i class="bi bi-stars fs-3 text-primary"></i>

                                <div class="mt-3 fw-semibold">

                                    AI Planner

                                </div>

                            </div>

                        </div>

                        <div class="card border-0 shadow-sm">

                            <div class="card-body text-center px-4">

                                <i class="bi bi-kanban fs-3 text-success"></i>

                                <div class="mt-3 fw-semibold">

                                    Projects

                                </div>

                            </div>

                        </div>

                        <div class="card border-0 shadow-sm">

                            <div class="card-body text-center px-4">

                                <i class="bi bi-people fs-3 text-warning"></i>

                                <div class="mt-3 fw-semibold">

                                    Teams

                                </div>

                            </div>

                        </div>

                    </div>

                    <div class="mt-5 d-flex gap-5 text-muted">

                        <div>

                            <i class="bi bi-shield-check me-2"></i>

                            Secure

                        </div>

                        <div>

                            <i class="bi bi-cloud-check me-2"></i>

                            Cloud

                        </div>

                        <div>

                            <i class="bi bi-lightning me-2"></i>

                            Fast

                        </div>

                    </div>

                </div>

            </div>

            <!-- RIGHT SIDE -->

            <div class="col-lg-6 d-flex align-items-center justify-content-center bg-light">

                <div id="login"
                     class="card border-0 shadow-lg"
                     style="width:100%;max-width:520px;border-radius:22px;">

                    <div class="card-body p-5">

                        <h2 class="fw-bold mb-2">

                            @(showRegister ? "Create Account" : "Welcome Back")

                        </h2>

                        <p class="text-muted mb-5">

                            @(showRegister
                                ? "Create your TaskFlow account."
                                : "Login to continue.")

                        </p>

                        <div class="d-flex mb-4">

                            <button id="loginBtn"
                                    type="button"
                                    onclick="showLogin()"
                                    class="btn w-50 @(showRegister ? "btn-light" : "btn-primary")">

                                Login

                            </button>

                            <button id="registerBtn"
                                    type="button"
                                    onclick="showRegister()"
                                    class="btn w-50 @(showRegister ? "btn-primary" : "btn-light")">

                                Register

                            </button>

                        </div>
                        <!-- LOGIN -->

                        <form id="loginForm"
                              asp-controller="Home"
                              asp-action="Login"
                              method="post"
                              style="display:@(showRegister ? "none" : "block");">

                            @Html.AntiForgeryToken()

                            <div class="mb-4">

                                <label class="form-label fw-semibold">

                                    Username

                                </label>

                                <input name="username"
                                       class="form-control form-control-lg"
                                       placeholder="Enter your username"
                                       required />

                            </div>

                            <div class="mb-3">

                                <div class="d-flex justify-content-between mb-2">

                                    <label class="form-label fw-semibold mb-0">

                                        Password

                                    </label>

                                    <a asp-action="ForgotPassword"
                                       class="small text-decoration-none">

                                        Forgot Password?

                                    </a>

                                </div>

                                <div class="input-group">

                                    <input id="loginPassword"
                                           name="password"
                                           type="password"
                                           class="form-control form-control-lg"
                                           placeholder="Enter your password"
                                           required />

                                    <button type="button"
                                            class="btn btn-outline-secondary"
                                            onclick="togglePassword('loginPassword',this)">

                                        <i class="bi bi-eye"></i>

                                    </button>

                                </div>

                            </div>

                            <div class="form-check mb-4">

                                <input class="form-check-input"
                                       type="checkbox"
                                       id="rememberMe">

                                <label class="form-check-label"
                                       for="rememberMe">

                                    Remember me

                                </label>

                            </div>

                            <button class="btn btn-primary btn-lg w-100">

                                <i class="bi bi-box-arrow-in-right me-2"></i>

                                Login

                            </button>

                        </form>
                        <!-- REGISTER -->

                        <form id="registerForm"
                              asp-controller="Home"
                              asp-action="Register"
                              method="post"
                              style="display:@(showRegister ? "block" : "none");">

                            @Html.AntiForgeryToken()

                            <div class="mb-3">

                                <label class="form-label fw-semibold">

                                    Username

                                </label>

                                <input name="username"
                                       class="form-control form-control-lg"
                                       placeholder="Choose a username"
                                       value="@ViewBag.RegisterUsername"
                                       minlength="3"
                                       maxlength="20"
                                       pattern="[A-Za-z0-9]+"
                                       required />

                            </div>

                            <div class="mb-3">

                                <label class="form-label fw-semibold">

                                    Email

                                </label>

                                <input name="email"
                                       type="email"
                                       class="form-control form-control-lg"
                                       placeholder="you@example.com"
                                       value="@ViewBag.RegisterEmail"
                                       required />

                            </div>

                            <div class="mb-3">

                                <label class="form-label fw-semibold">

                                    Password

                                </label>

                                <div class="input-group">

                                    <input id="registerPassword"
                                           name="password"
                                           type="password"
                                           class="form-control form-control-lg"
                                           placeholder="Create a password"
                                           minlength="6"
                                           required />

                                    <button type="button"
                                            class="btn btn-outline-secondary"
                                            onclick="togglePassword('registerPassword',this)">

                                        <i class="bi bi-eye"></i>

                                    </button>

                                </div>

                            </div>

                            <div class="mb-4">

                                <label class="form-label fw-semibold">

                                    Confirm Password

                                </label>

                                <div class="input-group">

                                    <input id="confirmPassword"
                                           name="confirmPassword"
                                           type="password"
                                           class="form-control form-control-lg"
                                           placeholder="Confirm password"
                                           minlength="6"
                                           required />

                                    <button type="button"
                                            class="btn btn-outline-secondary"
                                            onclick="togglePassword('confirmPassword',this)">

                                        <i class="bi bi-eye"></i>

                                    </button>

                                </div>

                            </div>

                            <button class="btn btn-primary btn-lg w-100">

                                <i class="bi bi-person-plus me-2"></i>

                                Create Account

                            </button>

                            <p class="text-center text-muted small mt-4 mb-0">

                                Email verification is required before your first login.

                            </p>

                        </form>
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger mt-4">

                                <i class="bi bi-exclamation-circle me-2"></i>

                                @ViewBag.Error

                            </div>
                        }

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

    html,
    body {
        margin: 0;
        min-height: 100%;
    }

    body {
        overflow-x: hidden;
        background: #ffffff;
    }

    .page-content {
        padding: 0 !important;
    }

        .page-content > .container {
            width: 100%;
            max-width: none !important;
            margin: 0 !important;
            padding: 0 !important;
        }

    footer {
        display: none;
    }

    .landing-page {
        width: 100%;
        min-height: calc(100vh - 73px);
        background: #ffffff;
    }

        .landing-page > .container-fluid {
            width: 100%;
            min-height: calc(100vh - 73px);
            padding: 0;
        }

            .landing-page > .container-fluid > .row {
                min-height: calc(100vh - 73px);
                margin: 0;
            }

                .landing-page > .container-fluid > .row > [class*="col-"] {
                    padding-right: 0;
                    padding-left: 0;
                }


        /* LEFT PANEL */

        .landing-page .col-lg-6:first-child {
            position: relative;
            display: flex;
            align-items: center;
            min-height: calc(100vh - 73px);
            padding: 48px 7%;
            overflow: hidden;
            background: radial-gradient( circle at 10% 15%, rgba(79, 70, 229, .09), transparent 34% ), radial-gradient( circle at 90% 85%, rgba(124, 58, 237, .06), transparent 36% ), #ffffff;
        }

            .landing-page .col-lg-6:first-child > div {
                position: relative;
                z-index: 2;
                width: 100%;
                max-width: 500px !important;
                margin: 0 auto !important;
            }

            .landing-page .col-lg-6:first-child::before {
                position: absolute;
                top: 12%;
                right: -110px;
                width: 280px;
                height: 280px;
                content: "";
                border: 1px solid rgba(79, 70, 229, .08);
                border-radius: 50%;
            }

            .landing-page .col-lg-6:first-child::after {
                position: absolute;
                bottom: -180px;
                left: -160px;
                width: 420px;
                height: 420px;
                content: "";
                background: rgba(79, 70, 229, .035);
                border-radius: 50%;
            }

            .landing-page .col-lg-6:first-child h2 {
                margin-bottom: 38px !important;
                color: #111827;
                font-size: 23px;
                font-weight: 800 !important;
                letter-spacing: -.8px;
            }

            .landing-page .col-lg-6:first-child .badge {
                margin-bottom: 24px !important;
                padding: 8px 13px !important;
                font-size: 11px;
                font-weight: 600;
            }

        .landing-page .display-3 {
            margin: 0;
            color: #111827;
            font-size: clamp(54px, 5vw, 76px);
            font-weight: 800 !important;
            letter-spacing: -4px;
            line-height: .98 !important;
        }

        .landing-page .lead {
            max-width: 390px;
            margin-top: 25px !important;
            margin-bottom: 0;
            color: #6b7280 !important;
            font-size: 17px;
            line-height: 1.65;
        }

        .landing-page .col-lg-6:first-child > div > .d-flex.gap-3 {
            gap: 12px !important;
            margin-top: 35px !important;
        }

        .landing-page .col-lg-6:first-child .card {
            width: 125px;
            min-width: 0;
            border: 1px solid #e9ebf0 !important;
            border-radius: 13px;
            box-shadow: 0 8px 25px rgba(17, 24, 39, .05) !important;
        }

        .landing-page .col-lg-6:first-child .card-body {
            padding: 17px 12px !important;
        }

            .landing-page .col-lg-6:first-child .card-body i {
                font-size: 23px !important;
            }

            .landing-page .col-lg-6:first-child .card-body .mt-3 {
                margin-top: 10px !important;
            }

            .landing-page .col-lg-6:first-child .card-body .fw-semibold {
                font-size: 13px;
            }

        .landing-page .col-lg-6:first-child > div > .mt-5.d-flex {
            gap: 30px !important;
            margin-top: 34px !important;
            font-size: 13px;
        }


        /* RIGHT PANEL */

        .landing-page .col-lg-6:last-child {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: calc(100vh - 73px);
            padding: 40px 6%;
            background: #f7f8fb !important;
        }

            .landing-page .col-lg-6:last-child::before {
                position: absolute;
                inset: 0;
                content: "";
                opacity: .3;
                background-image: linear-gradient( rgba(17, 24, 39, .025) 1px, transparent 1px ), linear-gradient( 90deg, rgba(17, 24, 39, .025) 1px, transparent 1px );
                background-size: 32px 32px;
                pointer-events: none;
            }

            .landing-page .col-lg-6:last-child > .card {
                position: relative;
                z-index: 2;
                width: 100% !important;
                max-width: 440px !important;
                margin: 0;
                border: 1px solid #e4e7ec !important;
                border-radius: 18px !important;
                box-shadow: 0 20px 55px rgba(17, 24, 39, .09) !important;
            }

                .landing-page .col-lg-6:last-child > .card .card-body {
                    padding: 34px !important;
                }

            .landing-page .col-lg-6:last-child h2 {
                margin-bottom: 6px !important;
                color: #111827;
                font-size: 27px;
                font-weight: 800 !important;
                letter-spacing: -.8px;
            }

                .landing-page .col-lg-6:last-child h2 + p {
                    margin-bottom: 28px !important;
                    font-size: 14px;
                }


    /* LOGIN REGISTER TABS */

    #loginBtn,
    #registerBtn {
        min-height: 42px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
    }

        #loginBtn.btn-light,
        #registerBtn.btn-light {
            color: #6b7280;
            background: #f3f4f6;
            border-color: #f3f4f6;
        }


    /* FORMS */

    .landing-page .form-label {
        margin-bottom: 6px;
        color: #374151;
        font-size: 13px;
        font-weight: 600 !important;
    }

    .landing-page .form-control {
        min-height: 46px;
        padding: 10px 13px;
        color: #111827;
        background: #ffffff;
        border: 1px solid #dfe3e8;
        border-radius: 9px;
        font-size: 14px;
    }

    .landing-page .form-control-lg {
        min-height: 46px;
        font-size: 14px;
    }

    .landing-page .form-control::placeholder {
        color: #9ca3af;
    }

    .landing-page .form-control:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, .10);
    }

    .landing-page .input-group .form-control {
        border-radius: 9px 0 0 9px;
    }

    .landing-page .input-group .btn {
        min-width: 48px;
        border-color: #dfe3e8;
        border-radius: 0 9px 9px 0;
    }

    #loginForm .mb-4,
    #registerForm .mb-4 {
        margin-bottom: 20px !important;
    }

    #loginForm .mb-3,
    #registerForm .mb-3 {
        margin-bottom: 17px !important;
    }

    .landing-page .form-check {
        margin-bottom: 22px !important;
    }

    .landing-page .form-check-label {
        color: #6b7280;
        font-size: 13px;
    }

    .landing-page .form-check-input:checked {
        background-color: #4f46e5;
        border-color: #4f46e5;
    }

    .landing-page .btn-primary {
        background: #4f46e5;
        border-color: #4f46e5;
    }

        .landing-page .btn-primary:hover {
            background: #4338ca;
            border-color: #4338ca;
        }

    #loginForm > .btn-primary,
    #registerForm > .btn-primary {
        min-height: 48px;
        padding: 10px 20px;
        border-radius: 9px;
        font-size: 14px;
        font-weight: 600;
        box-shadow: 0 8px 20px rgba(79, 70, 229, .16);
    }

    .landing-page .alert {
        border-radius: 9px;
        font-size: 13px;
    }


    /* TABLET */

    @@media (max-width: 1100px) {

        .landing-page .col-lg-6:first-child {
            padding: 45px 5%;
        }

        .landing-page .col-lg-6:last-child {
            padding: 40px 4%;
        }

        .landing-page .display-3 {
            font-size: 58px;
        }

        .landing-page .col-lg-6:first-child .card {
            width: 110px;
        }
    }


    /* MOBILE */

    @@media (max-width: 991px) {

        .landing-page,
        .landing-page > .container-fluid,
        .landing-page > .container-fluid > .row {
            min-height: auto;
        }

            .landing-page .col-lg-6:first-child {
                min-height: auto;
                padding: 50px 24px;
                text-align: center;
            }

                .landing-page .col-lg-6:first-child > div {
                    max-width: 600px !important;
                }

                .landing-page .col-lg-6:first-child h2 {
                    margin-bottom: 30px !important;
                }

            .landing-page .lead {
                margin-right: auto;
                margin-left: auto;
            }

            .landing-page .col-lg-6:first-child > div > .d-flex {
                justify-content: center;
            }

            .landing-page .col-lg-6:last-child {
                min-height: auto;
                padding: 55px 20px;
            }
    }

    @@media (max-width: 576px) {

        .landing-page .col-lg-6:first-child {
            padding: 38px 16px;
        }

        .landing-page .display-3 {
            font-size: 45px;
            letter-spacing: -2.5px;
        }

        .landing-page .lead {
            margin-top: 20px !important;
            font-size: 15px;
        }

        .landing-page .col-lg-6:first-child > div > .d-flex.gap-3 {
            width: 100%;
            gap: 8px !important;
            margin-top: 28px !important;
        }

        .landing-page .col-lg-6:first-child .card {
            width: calc(33.333% - 6px);
        }

        .landing-page .col-lg-6:first-child .card-body {
            padding: 15px 7px !important;
        }

            .landing-page .col-lg-6:first-child .card-body .fw-semibold {
                font-size: 11px;
            }

        .landing-page .col-lg-6:first-child > div > .mt-5.d-flex {
            gap: 18px !important;
            margin-top: 28px !important;
            font-size: 12px;
        }

        .landing-page .col-lg-6:last-child {
            padding: 30px 12px;
        }

            .landing-page .col-lg-6:last-child > .card {
                max-width: 100% !important;
                border-radius: 15px !important;
            }

                .landing-page .col-lg-6:last-child > .card .card-body {
                    padding: 25px 20px !important;
                }

            .landing-page .col-lg-6:last-child h2 {
                font-size: 24px;
            }
    }

</style>



@section Scripts {

    <script>

        function showLogin(){

        document.getElementById("loginForm").style.display="block";
        document.getElementById("registerForm").style.display="none";

        document.getElementById("loginBtn")
        .classList.remove("btn-light");
        document.getElementById("loginBtn")
        .classList.add("btn-primary");

        document.getElementById("registerBtn")
        .classList.remove("btn-primary");
        document.getElementById("registerBtn")
        .classList.add("btn-light");

        }

        function showRegister(){

        document.getElementById("loginForm").style.display="none";
        document.getElementById("registerForm").style.display="block";

        document.getElementById("registerBtn")
        .classList.remove("btn-light");
        document.getElementById("registerBtn")
        .classList.add("btn-primary");

        document.getElementById("loginBtn")
        .classList.remove("btn-primary");
        document.getElementById("loginBtn")
        .classList.add("btn-light");

        }

        function togglePassword(id,button){

        const input=document.getElementById(id);

        const icon=button.querySelector("i");

        if(input.type==="password"){

        input.type="text";

        icon.className="bi bi-eye-slash";

        }
        else{

        input.type="password";

        icon.className="bi bi-eye";

        }

        }

                const section = '@ViewBag.Section';

        if (section === 'login') {
            showLogin();

            setTimeout(() => {
                document
                    .getElementById('login')
                    ?.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
            }, 100);
        }



    </script>

}
