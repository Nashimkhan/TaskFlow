@{
    ViewData["Title"] = "AI Powered Task Management";

    var showRegister = ViewBag.ShowRegister == true;
}

<style>

    .auth-error-message {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 14px 16px;
        color: #991b1b;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 10px;
        font-size: 13px;
    }

    .auth-error-icon {
        width: 32px;
        height: 32px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #dc2626;
        background: #fee2e2;
        border-radius: 8px;
    }

    .auth-error-message strong {
        display: block;
        margin-bottom: 2px;
        color: #7f1d1d;
    }

    .home-page {
        background: #ffffff;
    }

    .hero-section {
        padding: 110px 0 90px;
        background: radial-gradient(circle at 80% 20%, rgba(79, 70, 229, .12), transparent 35%), radial-gradient(circle at 20% 80%, rgba(124, 58, 237, .08), transparent 35%), #ffffff;
        overflow: hidden;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border: 1px solid #e5e7eb;
        border-radius: 100px;
        background: #ffffff;
        font-size: 14px;
        font-weight: 600;
        color: #4f46e5;
        box-shadow: 0 4px 20px rgba(0,0,0,.04);
    }

    .hero-title {
        margin-top: 28px;
        font-size: clamp(48px, 6vw, 82px);
        line-height: .98;
        letter-spacing: -4px;
        font-weight: 800;
        color: #111827;
    }

    .gradient-text {
        background: linear-gradient(90deg, #4f46e5, #7c3aed);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .hero-description {
        max-width: 590px;
        margin-top: 28px;
        font-size: 20px;
        line-height: 1.7;
        color: #6b7280;
    }

    .primary-cta {
        background: #111827;
        color: white;
        border-radius: 10px;
        padding: 14px 24px;
        font-weight: 600;
        text-decoration: none;
        transition: .25s;
    }

        .primary-cta:hover {
            background: #4f46e5;
            color: white;
            transform: translateY(-2px);
        }

    .secondary-cta {
        background: white;
        color: #111827;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        padding: 14px 24px;
        font-weight: 600;
        text-decoration: none;
        transition: .25s;
    }

        .secondary-cta:hover {
            border-color: #111827;
            color: #111827;
            transform: translateY(-2px);
        }

    .ai-window {
        background: #111318;
        border: 1px solid #272a31;
        border-radius: 18px;
        padding: 18px;
        box-shadow: 0 35px 80px rgba(17,24,39,.22);
        transform: rotate(1.5deg);
    }

    .window-bar {
        display: flex;
        gap: 7px;
        margin-bottom: 25px;
    }

    .window-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #4b5563;
    }

    .ai-label {
        color: #818cf8;
        font-size: 13px;
        font-weight: 600;
    }

    .ai-goal {
        color: white;
        font-size: 22px;
        font-weight: 600;
        margin: 10px 0 25px;
    }

    .ai-task {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px;
        margin-bottom: 10px;
        border: 1px solid #292d35;
        background: #191c22;
        border-radius: 10px;
        color: #d1d5db;
    }

    .task-number {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 28px;
        height: 28px;
        background: rgba(99,102,241,.15);
        color: #a5b4fc;
        border-radius: 7px;
        font-size: 13px;
    }

    .trusted-text {
        color: #9ca3af;
        font-size: 14px;
    }

    .feature-section {
        padding: 110px 0;
        background: #f9fafb;
        border-top: 1px solid #f0f0f0;
    }

    .section-heading {
        max-width: 650px;
        margin-bottom: 60px;
    }

        .section-heading h2 {
            color: #111827;
            font-size: clamp(38px, 5vw, 58px);
            letter-spacing: -2px;
            font-weight: 800;
        }

        .section-heading p {
            color: #6b7280;
            font-size: 18px;
            line-height: 1.7;
        }

    .modern-card {
        height: 100%;
        padding: 32px;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        transition: .3s;
    }

        .modern-card:hover {
            transform: translateY(-6px);
            border-color: #c7d2fe;
            box-shadow: 0 20px 50px rgba(0,0,0,.07);
        }

    .feature-icon {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: #eef2ff;
        color: #4f46e5;
        font-size: 22px;
        margin-bottom: 25px;
    }

    .modern-card h4 {
        color: #111827;
        font-weight: 700;
    }

    .modern-card p {
        color: #6b7280;
        line-height: 1.7;
        margin: 0;
    }

    .about-section {
        padding: 110px 0;
        background: #111318;
        color: white;
    }

        .about-section h2 {
            font-size: clamp(38px, 5vw, 60px);
            letter-spacing: -2px;
            font-weight: 800;
        }

    .about-description {
        color: #9ca3af;
        font-size: 19px;
        line-height: 1.8;
    }

    .tech-item {
        padding: 16px 20px;
        background: #191c22;
        border: 1px solid #292d35;
        border-radius: 10px;
        color: #d1d5db;
    }

    .auth-section {
        padding: 110px 0;
        background: #ffffff;
    }

    .auth-card {
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 35px;
        box-shadow: 0 25px 60px rgba(0,0,0,.08);
    }

        .auth-card .form-control {
            padding: 13px 15px;
            border-radius: 9px;
            border-color: #e5e7eb;
        }

            .auth-card .form-control:focus {
                border-color: #6366f1;
                box-shadow: 0 0 0 4px rgba(99,102,241,.1);
            }

    .auth-toggle {
        background: #f3f4f6;
        padding: 5px;
        border-radius: 10px;
    }

    .toggle-btn {
        border: none;
        border-radius: 7px;
        padding: 10px;
    }


    @@media(max-width: 991px) {
        .hero-section {
            padding: 70px 0;
        }

        .hero-title {
            letter-spacing: -2px;
        }

        .ai-window {
            margin-top: 60px;
            transform: none;
        }
    }
</style>

<div class="home-page">

    <!-- HERO -->

    <section class="hero-section">

        <div class="container">

            <div class="row align-items-center g-5">

                <div class="col-lg-6">

                    <div class="hero-badge">
                        <i class="bi bi-stars"></i>
                        AI-powered productivity
                    </div>

                    <h1 class="hero-title">
                        Plan smarter.<br />
                        <span class="gradient-text">
                            Finish faster.
                        </span>
                    </h1>

                    <p class="hero-description">
                        Turn ambitious goals into clear, actionable tasks
                        with AI-powered planning and intelligent productivity tools.
                    </p>

                    <div class="d-flex flex-wrap gap-3 mt-4">

                        <a href="#login"
                           class="primary-cta">

                            Get started
                            <i class="bi bi-arrow-right ms-2"></i>

                        </a>

                        <a asp-controller="Task"
                           asp-action="AiBreakdown"
                           class="secondary-cta">

                            <i class="bi bi-stars me-2"></i>
                            Try AI planner

                        </a>

                    </div>

                    <div class="mt-5 trusted-text">

                        <i class="bi bi-shield-check me-2"></i>
                        Secure authentication

                        <span class="mx-3">•</span>

                        <i class="bi bi-cloud-check me-2"></i>
                        Cloud powered

                    </div>

                </div>

                <div class="col-lg-6">

                    <div class="ai-window">

                        <div class="window-bar">
                            <span class="window-dot"></span>
                            <span class="window-dot"></span>
                            <span class="window-dot"></span>
                        </div>

                        <div class="ai-label">
                            TASKFLOW AI
                        </div>

                        <div class="ai-goal">
                            Prepare for my .NET developer interview
                        </div>

                        <div class="ai-task">
                            <span class="task-number">01</span>
                            Revise C# and OOP fundamentals
                        </div>

                        <div class="ai-task">
                            <span class="task-number">02</span>
                            Practice SQL joins and queries
                        </div>

                        <div class="ai-task">
                            <span class="task-number">03</span>
                            Review Entity Framework Core
                        </div>

                        <div class="ai-task">
                            <span class="task-number">04</span>
                            Explain ASP.NET Core MVC architecture
                        </div>

                        <div class="ai-task">
                            <span class="task-number">05</span>
                            Complete a mock technical interview
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>


    <!-- FEATURES -->

    <section id="features"
             class="feature-section">

        <div class="container">

            <div class="section-heading">

                <span class="text-primary fw-semibold">
                    FEATURES
                </span>

                <h2 class="mt-3">
                    Everything you need to stay focused.
                </h2>

                <p class="mt-3">
                    Built to combine task management, AI planning,
                    security and productivity in one clean experience.
                </p>

            </div>

            <div class="row g-4">

                <div class="col-md-6 col-lg-4">

                    <div class="modern-card">

                        <div class="feature-icon">
                            <i class="bi bi-stars"></i>
                        </div>

                        <h4>AI Task Planner</h4>

                        <p>
                            Transform one goal into five practical tasks
                            with smart priorities and suggested due dates.
                        </p>

                    </div>

                </div>

                <div class="col-md-6 col-lg-4">

                    <div class="modern-card">

                        <div class="feature-icon">
                            <i class="bi bi-grid-1x2"></i>
                        </div>

                        <h4>Smart Dashboard</h4>

                        <p>
                            Monitor completed, pending and overdue tasks
                            from one focused dashboard.
                        </p>

                    </div>

                </div>

                <div class="col-md-6 col-lg-4">

                    <div class="modern-card">

                        <div class="feature-icon">
                            <i class="bi bi-shield-lock"></i>
                        </div>

                        <h4>Secure Authentication</h4>

                        <p>
                            ASP.NET Core Identity, email verification
                            and secure password recovery.
                        </p>

                    </div>

                </div>

                <div class="col-md-6 col-lg-4">

                    <div class="modern-card">

                        <div class="feature-icon">
                            <i class="bi bi-person-gear"></i>
                        </div>

                        <h4>Admin Management</h4>

                        <p>
                            Role-based administration with registered
                            user management and secure authorization.
                        </p>

                    </div>

                </div>

                <div class="col-md-6 col-lg-4">

                    <div class="modern-card">

                        <div class="feature-icon">
                            <i class="bi bi-search"></i>
                        </div>

                        <h4>Search & Filters</h4>

                        <p>
                            Quickly find tasks by keyword, status
                            and priority with pagination support.
                        </p>

                    </div>

                </div>

                <div class="col-md-6 col-lg-4">

                    <div class="modern-card">

                        <div class="feature-icon">
                            <i class="bi bi-cloud"></i>
                        </div>

                        <h4>Cloud Ready</h4>

                        <p>
                            PostgreSQL-backed architecture designed
                            for modern cloud deployment.
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </section>


    <!-- ABOUT -->

    <section id="about"
             class="about-section">

        <div class="container">

            <div class="row align-items-center g-5">

                <div class="col-lg-6">

                    <span class="text-primary fw-semibold">
                        ABOUT TASKFLOW
                    </span>

                    <h2 class="mt-3">
                        Productivity powered by practical AI.
                    </h2>

                    <p class="about-description mt-4">
                        TaskFlow is an AI-powered task management application
                        built with ASP.NET Core MVC. It combines intelligent
                        task planning with secure authentication and structured
                        task management.
                    </p>

                </div>

                <div class="col-lg-6">

                    <div class="d-grid gap-3">

                        <div class="tech-item">
                            <i class="bi bi-code-slash me-3"></i>
                            ASP.NET Core MVC
                        </div>

                        <div class="tech-item">
                            <i class="bi bi-database me-3"></i>
                            Entity Framework Core + PostgreSQL
                        </div>

                        <div class="tech-item">
                            <i class="bi bi-shield-check me-3"></i>
                            ASP.NET Core Identity
                        </div>

                        <div class="tech-item">
                            <i class="bi bi-stars me-3"></i>
                            Groq AI Integration
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>


    <!-- LOGIN / REGISTER -->

    <section id="login"
             class="auth-section">

        <div class="container">

            <div class="row justify-content-center">

                <div class="col-lg-5 col-md-7">

                    <div class="text-center mb-5">

                        <h2 class="fw-bold">
                            Start planning smarter.
                        </h2>

                        <p class="text-muted">
                            Login or create your TaskFlow account.
                        </p>

                    </div>

                    <div class="auth-card">

                

                        <div class="d-flex auth-toggle mb-4">

                            <button id="loginBtn"
                                    type="button"
                                    class="btn @(showRegister ? "" : "bg-white shadow-sm") w-50 toggle-btn"
                                    onclick="showLogin()">

                                Login

                            </button>

                            <button id="registerBtn"
                                    type="button"
                                    class="btn @(showRegister ? "bg-white shadow-sm" : "") w-50 toggle-btn"
                                    onclick="showRegister()">

                                Register

                            </button>

                        </div>

                        <!-- LOGIN -->

                        <form id="loginForm"
                              method="post"
                              asp-controller="Home"
                              asp-action="Login"
                              style="display:@(showRegister ? "none" : "block");">

                            @Html.AntiForgeryToken()

                            <input name="username"
                                   class="form-control mb-3"
                                   placeholder="Username"
                                   required />

                            <input name="password"
                                   type="password"
                                   class="form-control mb-2"
                                   placeholder="Password"
                                   required />

                            <div class="text-end mb-3">

                                <a asp-controller="Home"
                                   asp-action="ForgotPassword"
                                   class="small text-decoration-none">

                                    Forgot password?

                                </a>

                            </div>

                            <button type="submit"
                                    class="btn btn-dark w-100 py-3">

                                Login

                            </button>

                        </form>


                        <!-- REGISTER -->

                        <form id="registerForm"
                              method="post"
                              asp-controller="Home"
                              asp-action="Register"
                              style="display:@(showRegister ? "block" : "none");">

                            @Html.AntiForgeryToken()

                            <input name="username"
                                   class="form-control mb-3"
                                   placeholder="Choose username"
                                   minlength="3"
                                   maxlength="20"
                                   pattern="[A-Za-z0-9]+"
                                   title="Only letters and numbers are allowed"
                                   value="@ViewBag.RegisterUsername"
                                   required />

                            <input name="email"
                                   type="email"
                                   class="form-control mb-2"
                                   placeholder="Email address"
                                   value="@ViewBag.RegisterEmail"
                                   required />

                            <small class="text-muted d-block mb-3">
                                A verification link will be sent to your email.
                            </small>

                            <input name="password"
                                   type="password"
                                   class="form-control mb-3"
                                   placeholder="Create password"
                                   minlength="6"
                                   required />

                            <input name="confirmPassword"
                                   type="password"
                                   class="form-control mb-3"
                                   placeholder="Confirm password"
                                   minlength="6"
                                   required />

                            <button type="submit"
                                    class="btn btn-dark w-100 py-3">

                                Create account

                            </button>

                        </form>

                        @if (ViewBag.Error != null)
                        {
                            <div class="auth-error-message mt-3">

                                <div class="auth-error-icon">
                                    <i class="bi bi-exclamation-circle"></i>
                                </div>

                                <div>
                                    <strong>Unable to continue</strong>

                                    <p class="mb-0">
                                        @ViewBag.Error
                                    </p>
                                </div>

                            </div>
                        }

                    </div>

                </div>

            </div>

        </div>

    </section>

</div>

@section Scripts {

    <script>

        function showLogin() {

            document.getElementById("loginForm").style.display = "block";
            document.getElementById("registerForm").style.display = "none";

            document.getElementById("loginBtn")
                .classList.add("bg-white", "shadow-sm");

            document.getElementById("registerBtn")
                .classList.remove("bg-white", "shadow-sm");
        }

        function showRegister() {

            document.getElementById("loginForm").style.display = "none";
            document.getElementById("registerForm").style.display = "block";

            document.getElementById("registerBtn")
                .classList.add("bg-white", "shadow-sm");

            document.getElementById("loginBtn")
                .classList.remove("bg-white", "shadow-sm");
        }

       

    </script>

}