@{
    ViewData["Title"] = "TaskFlow";

    var showRegister = ViewBag.ShowRegister == true;
}

<style>

    /* =========================================
           HOME PAGE RESET
        ========================================= */

    body {
        margin: 0;
        background: #f8fafc;
    }

        body > main {
            width: 100%;
            margin: 0;
            padding: 0 !important;
        }

    footer {
        display: none;
    }


    /* =========================================
           PAGE
        ========================================= */

    .taskflow-home {
        width: 100%;
        min-height: calc(100vh - 74px);
        padding: clamp(30px, 5vh, 70px) clamp(24px, 6vw, 100px);
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
    }

    .taskflow-container {
        width: 100%;
        max-width: 1280px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(360px, 440px);
        gap: clamp(50px, 7vw, 110px);
        align-items: center;
    }


    /* =========================================
           PRODUCT CONTENT
        ========================================= */

    .product-section {
        width: 100%;
        min-width: 0;
    }

    .product-content {
        width: 100%;
        max-width: 620px;
    }

    .product-label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px;
        margin-bottom: 22px;
        color: #4338ca;
        background: #eef2ff;
        border-radius: 100px;
        font-size: 12px;
        font-weight: 600;
    }

        .product-label i {
            font-size: 13px;
        }

    .product-title {
        margin: 0;
        color: #111827;
        font-size: clamp(42px, 4.3vw, 68px);
        font-weight: 800;
        letter-spacing: clamp(-3px, -.2vw, -1.5px);
        line-height: 1;
    }

        .product-title span {
            color: #4f46e5;
        }

    .product-description {
        max-width: 540px;
        margin: 24px 0 0;
        color: #6b7280;
        font-size: clamp(15px, 1.2vw, 17px);
        line-height: 1.7;
    }


    /* =========================================
           AI DEMO
        ========================================= */

    .ai-demo {
        max-width: 560px;
        margin-top: 34px;
        padding: 20px;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        box-shadow: 0 10px 30px rgba(17, 24, 39, .04);
    }

    .ai-demo-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 15px;
        margin-bottom: 16px;
    }

    .ai-demo-brand {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #111827;
        font-size: 13px;
        font-weight: 700;
    }

        .ai-demo-brand i {
            color: #4f46e5;
        }

    .ai-demo-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #15803d;
        font-size: 11px;
        font-weight: 600;
    }

        .ai-demo-status::before {
            width: 6px;
            height: 6px;
            content: "";
            background: #22c55e;
            border-radius: 50%;
        }

    .ai-demo-goal {
        margin-bottom: 14px;
        color: #6b7280;
        font-size: 13px;
        line-height: 1.5;
    }

        .ai-demo-goal strong {
            color: #111827;
            font-weight: 600;
        }

    .ai-task-list {
        display: grid;
        gap: 8px;
    }

    .ai-task-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 11px;
        background: #f8fafc;
        border-radius: 8px;
        color: #4b5563;
        font-size: 12px;
    }

    .ai-task-number {
        width: 24px;
        height: 24px;
        flex: 0 0 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #4f46e5;
        background: #eef2ff;
        border-radius: 6px;
        font-size: 10px;
        font-weight: 700;
    }


    /* =========================================
           STACK
        ========================================= */

    .tech-stack {
        margin-top: 25px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px 22px;
        color: #9ca3af;
        font-size: 11px;
    }

        .tech-stack span {
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }


    /* =========================================
           AUTH SECTION
        ========================================= */

    .auth-section {
        width: 100%;
        min-width: 0;
    }

    .auth-card {
        width: 100%;
        padding: clamp(28px, 3vw, 40px);
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 18px 50px rgba(17, 24, 39, .07);
    }

    .auth-header {
        margin-bottom: 26px;
    }

    .auth-title {
        margin: 0 0 8px;
        color: #111827;
        font-size: clamp(26px, 2.3vw, 32px);
        font-weight: 800;
        letter-spacing: -1px;
    }

    .auth-subtitle {
        margin: 0;
        color: #6b7280;
        font-size: 14px;
        line-height: 1.5;
    }


    /* =========================================
           AUTH TABS
        ========================================= */

    .auth-tabs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4px;
        padding: 4px;
        margin-bottom: 25px;
        background: #f3f4f6;
        border-radius: 10px;
    }

    .auth-tab {
        min-height: 42px;
        padding: 8px 12px;
        color: #6b7280;
        background: transparent;
        border: 0;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background .2s ease, color .2s ease, box-shadow .2s ease;
    }

        .auth-tab.active {
            color: #ffffff;
            background: #4f46e5;
            box-shadow: 0 5px 14px rgba(79, 70, 229, .18);
        }


    /* =========================================
           FORM
        ========================================= */

    .form-field {
        margin-bottom: 17px;
    }

    .field-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 15px;
        margin-bottom: 7px;
    }

    .field-label {
        display: block;
        margin: 0 0 7px;
        color: #374151;
        font-size: 13px;
        font-weight: 600;
    }

    .field-header .field-label {
        margin-bottom: 0;
    }

    .forgot-link {
        color: #4f46e5;
        font-size: 12px;
        font-weight: 500;
        text-decoration: none;
    }

        .forgot-link:hover {
            color: #3730a3;
            text-decoration: underline;
        }

    .auth-input {
        width: 100%;
        min-height: 48px;
        padding: 11px 14px;
        color: #111827;
        background: #ffffff;
        border: 1px solid #d1d5db;
        border-radius: 9px;
        outline: none;
        font-size: 14px;
        transition: border-color .2s ease, box-shadow .2s ease;
    }

        .auth-input::placeholder {
            color: #9ca3af;
        }

        .auth-input:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, .10);
        }


    /* =========================================
           PASSWORD
        ========================================= */

    .password-wrapper {
        position: relative;
    }

        .password-wrapper .auth-input {
            padding-right: 50px;
        }

    .password-toggle {
        position: absolute;
        top: 0;
        right: 0;
        width: 48px;
        height: 48px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6b7280;
        background: transparent;
        border: 0;
        cursor: pointer;
    }

        .password-toggle:hover {
            color: #4f46e5;
        }


    /* =========================================
           REMEMBER
        ========================================= */

    .remember-row {
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .remember-row input {
            width: 16px;
            height: 16px;
            margin: 0;
            accent-color: #4f46e5;
        }

        .remember-row label {
            margin: 0;
            color: #6b7280;
            font-size: 13px;
        }


    /* =========================================
           BUTTON
        ========================================= */

    .auth-submit {
        width: 100%;
        min-height: 48px;
        padding: 11px 20px;
        color: #ffffff;
        background: #4f46e5;
        border: 0;
        border-radius: 9px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: background .2s ease, transform .2s ease;
    }

        .auth-submit:hover {
            color: #ffffff;
            background: #4338ca;
            transform: translateY(-1px);
        }

        .auth-submit:disabled {
            cursor: not-allowed;
            opacity: .75;
            transform: none;
        }


    /* =========================================
           REGISTER / ERROR
        ========================================= */

    .register-note {
        margin: 17px 0 0;
        color: #9ca3af;
        font-size: 12px;
        line-height: 1.5;
        text-align: center;
    }

    .auth-error {
        margin-top: 20px;
        padding: 13px 15px;
        color: #b91c1c;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 9px;
        font-size: 13px;
        line-height: 1.5;
    }

    .auth-footer {
        margin-top: 22px;
        color: #9ca3af;
        font-size: 11px;
        line-height: 1.5;
        text-align: center;
    }


    /* =========================================
           TABLET
        ========================================= */

    @@media (max-width: 991px) {

        .taskflow-home {
            min-height: calc(100vh - 70px);
            padding: 45px 24px;
        }

        .taskflow-container {
            max-width: 560px;
            grid-template-columns: 1fr;
            gap: 35px;
        }

        .product-section {
            text-align: center;
        }

        .product-content {
            max-width: 560px;
            margin: 0 auto;
        }

        .product-title {
            font-size: clamp(40px, 8vw, 58px);
        }

        .product-description {
            margin-left: auto;
            margin-right: auto;
        }

        .ai-demo {
            margin-left: auto;
            margin-right: auto;
            text-align: left;
        }

        .tech-stack {
            justify-content: center;
        }

        .auth-section {
            max-width: 480px;
            margin: 0 auto;
        }
    }


    /* =========================================
           MOBILE
        ========================================= */

    @@media (max-width: 576px) {

        .taskflow-home {
            min-height: 100vh;
            padding: 28px 14px 40px;
            align-items: flex-start;
        }

        .taskflow-container {
            gap: 30px;
        }

        .product-label {
            margin-bottom: 17px;
        }

        .product-title {
            font-size: clamp(38px, 12vw, 48px);
            letter-spacing: -2px;
        }

        .product-description {
            margin-top: 18px;
            font-size: 14px;
        }

        .ai-demo {
            margin-top: 25px;
            padding: 16px;
            border-radius: 12px;
        }

        .ai-demo-header {
            align-items: flex-start;
        }

        .ai-task-item {
            align-items: flex-start;
        }

        .tech-stack {
            margin-top: 20px;
            gap: 10px 16px;
        }

        .auth-card {
            padding: 25px 20px;
            border-radius: 13px;
        }

        .auth-title {
            font-size: 25px;
        }

        .auth-header {
            margin-bottom: 22px;
        }

        .auth-tabs {
            margin-bottom: 22px;
        }
    }

</style>


<div class="taskflow-home">

    <div class="taskflow-container">


        <!-- =====================================
             PRODUCT
        ====================================== -->

        <section class="product-section">

            <div class="product-content">


                <div class="product-label">

                    <i class="bi bi-stars"></i>

                    AI powered task management

                </div>


                <h1 class="product-title">

                    Plan smarter.

                    <br />

                    Work with

                    <span>clarity.</span>

                </h1>


                <p class="product-description">

                    Organize projects, manage tasks and use AI
                    to turn complex goals into clear action steps.

                </p>



                <!-- AI DEMO -->

                <div class="ai-demo">


                    <div class="ai-demo-header">

                        <div class="ai-demo-brand">

                            <i class="bi bi-stars"></i>

                            TaskFlow AI

                        </div>


                        <div class="ai-demo-status">

                            Ready

                        </div>

                    </div>


                    <div class="ai-demo-goal">

                        Goal:

                        <strong>

                            Prepare for my .NET developer interview

                        </strong>

                    </div>


                    <div class="ai-task-list">


                        <div class="ai-task-item">

                            <span class="ai-task-number">

                                01

                            </span>

                            Review C# and object-oriented programming

                        </div>


                        <div class="ai-task-item">

                            <span class="ai-task-number">

                                02

                            </span>

                            Practice SQL queries and database concepts

                        </div>


                        <div class="ai-task-item">

                            <span class="ai-task-number">

                                03

                            </span>

                            Review ASP.NET Core and Entity Framework Core

                        </div>


                    </div>

                </div>



                <!-- TECH STACK -->

                <div class="tech-stack">

                    <span>

                        <i class="bi bi-code-slash"></i>

                        ASP.NET Core

                    </span>


                    <span>

                        <i class="bi bi-database"></i>

                        PostgreSQL

                    </span>


                    <span>

                        <i class="bi bi-shield-check"></i>

                        Identity

                    </span>


                    <span>

                        <i class="bi bi-stars"></i>

                        AI Integration

                    </span>

                </div>


            </div>

        </section>



        <!-- =====================================
             AUTH
        ====================================== -->

        <section class="auth-section">

            <div class="auth-card">


                <div class="auth-header">

                    <h2 id="authTitle"
                        class="auth-title">

                        @(showRegister
                            ? "Create your account"
                            : "Welcome back")

                    </h2>


                    <p id="authSubtitle"
                       class="auth-subtitle">

                        @(showRegister
                            ? "Create an account and start planning."
                            : "Sign in to continue to TaskFlow.")

                    </p>

                </div>



                <!-- AUTH TABS -->

                <div class="auth-tabs">


                    <button id="loginBtn"
                            type="button"
                            class="auth-tab @(showRegister ? "" : "active")"
                            onclick="showLogin()">

                        Login

                    </button>


                    <button id="registerBtn"
                            type="button"
                            class="auth-tab @(showRegister ? "active" : "")"
                            onclick="showRegister()">

                        Register

                    </button>


                </div>



                <!-- =================================
                     LOGIN
                ================================== -->

                <form id="loginForm"
                      asp-controller="Home"
                      asp-action="Login"
                      method="post"
                      style="display:@(showRegister ? "none" : "block");">


                    @Html.AntiForgeryToken()


                    <div class="form-field">

                        <label for="loginUsername"
                               class="field-label">

                            Username

                        </label>


                        <input id="loginUsername"
                               name="username"
                               type="text"
                               class="auth-input"
                               placeholder="Enter your username"
                               autocomplete="username"
                               required />

                    </div>



                    <div class="form-field">


                        <div class="field-header">

                            <label for="loginPassword"
                                   class="field-label">

                                Password

                            </label>


                            <a asp-controller="Home"
                               asp-action="ForgotPassword"
                               class="forgot-link">

                                Forgot password?

                            </a>

                        </div>


                        <div class="password-wrapper">

                            <input id="loginPassword"
                                   name="password"
                                   type="password"
                                   class="auth-input"
                                   placeholder="Enter your password"
                                   autocomplete="current-password"
                                   required />


                            <button type="button"
                                    class="password-toggle"
                                    onclick="togglePassword('loginPassword', this)"
                                    aria-label="Show or hide password">

                                <i class="bi bi-eye"></i>

                            </button>

                        </div>


                    </div>



                    <div class="remember-row">

                        <input id="rememberMe"
                               name="rememberMe"
                               type="checkbox"
                               value="true" />


                        <label for="rememberMe">

                            Remember me

                        </label>

                    </div>



                    <button type="submit"
                            class="auth-submit">

                        Sign in

                    </button>


                </form>



                <!-- =================================
                     REGISTER
                ================================== -->

                <form id="registerForm"
                      asp-controller="Home"
                      asp-action="Register"
                      method="post"
                      style="display:@(showRegister ? "block" : "none");">


                    @Html.AntiForgeryToken()


                    <div class="form-field">

                        <label for="registerUsername"
                               class="field-label">

                            Username

                        </label>


                        <input id="registerUsername"
                               name="username"
                               type="text"
                               class="auth-input"
                               placeholder="Choose a username"
                               value="@ViewBag.RegisterUsername"
                               autocomplete="username"
                               minlength="3"
                               maxlength="20"
                               pattern="[A-Za-z0-9]+"
                               required />

                    </div>



                    <div class="form-field">

                        <label for="registerEmail"
                               class="field-label">

                            Email

                        </label>


                        <input id="registerEmail"
                               name="email"
                               type="email"
                               class="auth-input"
                               placeholder="you@example.com"
                               value="@ViewBag.RegisterEmail"
                               autocomplete="email"
                               required />

                    </div>



                    <div class="form-field">

                        <label for="registerPassword"
                               class="field-label">

                            Password

                        </label>


                        <div class="password-wrapper">

                            <input id="registerPassword"
                                   name="password"
                                   type="password"
                                   class="auth-input"
                                   placeholder="Create a password"
                                   autocomplete="new-password"
                                   minlength="6"
                                   required />


                            <button type="button"
                                    class="password-toggle"
                                    onclick="togglePassword('registerPassword', this)"
                                    aria-label="Show or hide password">

                                <i class="bi bi-eye"></i>

                            </button>

                        </div>

                    </div>



                    <div class="form-field">

                        <label for="confirmPassword"
                               class="field-label">

                            Confirm password

                        </label>


                        <div class="password-wrapper">

                            <input id="confirmPassword"
                                   name="confirmPassword"
                                   type="password"
                                   class="auth-input"
                                   placeholder="Confirm your password"
                                   autocomplete="new-password"
                                   minlength="6"
                                   required />


                            <button type="button"
                                    class="password-toggle"
                                    onclick="togglePassword('confirmPassword', this)"
                                    aria-label="Show or hide password">

                                <i class="bi bi-eye"></i>

                            </button>

                        </div>

                    </div>



                    <button type="submit"
                            class="auth-submit">

                        Create account

                    </button>


                    <p class="register-note">

                        We'll send a verification link to your email.

                    </p>


                </form>



                <!-- ERROR -->
                @if (ViewBag.Error != null)
                {
                    <div class="auth-error">

                        <i class="bi bi-exclamation-circle me-2"></i>

                        @ViewBag.Error

                    </div>
                }



                <div class="auth-footer">

                    <i class="bi bi-shield-check me-1"></i>

                    Secure authentication with ASP.NET Core Identity

                </div>


            </div>

        </section>


    </div>

</div>


@section Scripts {

    <script>

        function showLogin() {

            const loginForm =
                document.getElementById("loginForm");

            const registerForm =
                document.getElementById("registerForm");

            const loginButton =
                document.getElementById("loginBtn");

            const registerButton =
                document.getElementById("registerBtn");


            loginForm.style.display = "block";

            registerForm.style.display = "none";


            loginButton.classList.add("active");

            registerButton.classList.remove("active");


            document.getElementById("authTitle")
                .textContent = "Welcome back";


            document.getElementById("authSubtitle")
                .textContent = "Sign in to continue to TaskFlow.";

        }



        function showRegister() {

            const loginForm =
                document.getElementById("loginForm");

            const registerForm =
                document.getElementById("registerForm");

            const loginButton =
                document.getElementById("loginBtn");

            const registerButton =
                document.getElementById("registerBtn");


            loginForm.style.display = "none";

            registerForm.style.display = "block";


            registerButton.classList.add("active");

            loginButton.classList.remove("active");


            document.getElementById("authTitle")
                .textContent = "Create your account";


            document.getElementById("authSubtitle")
                .textContent = "Create an account and start planning.";

        }



        function togglePassword(inputId, button) {

            const input =
                document.getElementById(inputId);

            const icon =
                button.querySelector("i");


            const passwordIsHidden =
                input.type === "password";


            input.type =
                passwordIsHidden
                    ? "text"
                    : "password";


            icon.className =
                passwordIsHidden
                    ? "bi bi-eye-slash"
                    : "bi bi-eye";

        }

    </script>

}