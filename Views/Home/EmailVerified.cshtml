@{
    Layout = null;
}

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>Email Verified - TaskFlow</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

</head>

<body class="bg-light">

    <div class="page d-flex align-items-center justify-content-center min-vh-100">

        <div class="container"
             style="max-width:460px;">

            <div class="card shadow-sm">

                <div class="card-body text-center p-5">

                    <div class="member-avatar mx-auto mb-4"
                         style="width:80px;height:80px;font-size:34px;background:#dcfce7;color:#16a34a;">

                        <i class="bi bi-check-circle-fill"></i>

                    </div>

                    <h1 class="page-title text-success">

                        Email Verified

                    </h1>

                    <p class="page-subtitle">

                        Your TaskFlow account has been activated successfully.

                    </p>

                    <div class="alert alert-success">

                        🎉 Welcome to TaskFlow!

                    </div>

                    <p class="text-muted">

                        You can now close this tab.

                        Your login page will automatically redirect you.

                    </p>

                    <a href="/#login"
                       class="btn btn-primary mt-3">

                        <i class="bi bi-box-arrow-in-right me-2"></i>

                        Go to Login

                    </a>

                </div>

            </div>

            <p class="text-center text-muted small mt-4">

                <i class="bi bi-shield-check me-1"></i>

                Secure verification completed successfully.

            </p>

        </div>

    </div>

</body>

</html>