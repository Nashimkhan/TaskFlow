@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <title>Reset Password - TaskFlow</title>

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                min-height: 100vh;
                background: radial-gradient(circle at 80% 20%, rgba(79, 70, 229, .10), transparent 35%), radial-gradient(circle at 20% 80%, rgba(124, 58, 237, .07), transparent 35%), #ffffff;
                color: #111827;
            }

            .auth-page {
                width: 100%;
                min-height: 100vh;
                padding: 40px 20px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .auth-wrapper {
                width: 100%;
                max-width: 460px;
            }

            .brand {
                display: block;
                margin-bottom: 45px;
                color: #111827;
                font-size: 24px;
                font-weight: 800;
                text-align: center;
                text-decoration: none;
                letter-spacing: -1px;
            }

            .icon-box {
                width: 58px;
                height: 58px;
                margin: 0 auto 24px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #4f46e5;
                background: #eef2ff;
                border-radius: 15px;
                font-size: 25px;
            }

            .auth-header {
                margin-bottom: 32px;
                text-align: center;
            }

                .auth-header h1 {
                    margin-bottom: 12px;
                    font-size: 34px;
                    font-weight: 800;
                    letter-spacing: -1.3px;
                }

                .auth-header p {
                    margin: 0;
                    color: #6b7280;
                    line-height: 1.7;
                }

            .auth-card {
                padding: 32px;
                background: #ffffff;
                border: 1px solid #e5e7eb;
                border-radius: 16px;
                box-shadow: 0 20px 60px rgba(0, 0, 0, .06);
            }

            .field-label {
                margin-bottom: 8px;
                color: #111827;
                font-size: 14px;
                font-weight: 600;
            }

            .password-wrapper {
                position: relative;
            }

            .password-input {
                min-height: 50px;
                padding: 12px 48px 12px 15px;
                border: 1px solid #e5e7eb;
                border-radius: 10px;
            }

                .password-input:focus {
                    border-color: #6366f1;
                    box-shadow: 0 0 0 4px rgba(99, 102, 241, .1);
                }

            .password-toggle {
                position: absolute;
                top: 50%;
                right: 15px;
                padding: 0;
                color: #9ca3af;
                background: transparent;
                border: none;
                transform: translateY(-50%);
            }

                .password-toggle:hover {
                    color: #111827;
                }

            .password-help {
                margin-top: 7px;
                color: #9ca3af;
                font-size: 12px;
            }

            .reset-btn {
                min-height: 50px;
                color: #ffffff;
                background: #111827;
                border: none;
                border-radius: 10px;
                font-weight: 600;
                transition: .25s;
            }

                .reset-btn:hover {
                    color: #ffffff;
                    background: #4f46e5;
                    transform: translateY(-1px);
                }

                .reset-btn:disabled {
                    color: #ffffff;
                    background: #4f46e5;
                }

            .error-message {
                margin-top: 20px;
                padding: 14px 16px;
                color: #b91c1c;
                background: #fef2f2;
                border: 1px solid #fecaca;
                border-radius: 10px;
                font-size: 14px;
            }

            .security-info {
                margin-top: 25px;
                color: #9ca3af;
                font-size: 12px;
                text-align: center;
            }

            @@media(max-width: 576px) {

                .auth-page {
                    padding: 30px 15px;
                }

                .brand {
                    margin-bottom: 35px;
                }

                .auth-header h1 {
                    font-size: 29px;
                }

                .auth-card {
                    padding: 24px;
                }
            }

    </style>

</head>

<body>

    <main class="auth-page">

        <div class="auth-wrapper">

            <a asp-controller="Home"
               asp-action="Index"
               class="brand">

                TaskFlow

            </a>


            <div class="auth-header">

                <div class="icon-box">

                    <i class="bi bi-shield-lock"></i>

                </div>

                <h1>
                    Create a new password.
                </h1>

                <p>
                    Choose a secure password for your TaskFlow account.
                </p>

            </div>


            <div class="auth-card">

                <form method="post"
                      asp-controller="Home"
                      asp-action="ResetPassword"
                      id="resetPasswordForm">

                    @Html.AntiForgeryToken()

                    <input type="hidden"
                           name="userId"
                           value="@ViewBag.UserId" />

                    <input type="hidden"
                           name="token"
                           value="@ViewBag.Token" />


                    <!-- PASSWORD -->

                    <div class="mb-4">

                        <label for="password"
                               class="field-label">

                            New password

                        </label>

                        <div class="password-wrapper">

                            <input id="password"
                                   name="password"
                                   type="password"
                                   class="form-control password-input"
                                   placeholder="Enter new password"
                                   minlength="6"
                                   autocomplete="new-password"
                                   required />

                            <button type="button"
                                    class="password-toggle"
                                    onclick="togglePassword('password', this)">

                                <i class="bi bi-eye"></i>

                            </button>

                        </div>

                        <div class="password-help">
                            Use at least 6 characters.
                        </div>

                    </div>


                    <!-- CONFIRM PASSWORD -->

                    <div class="mb-4">

                        <label for="confirmPassword"
                               class="field-label">

                            Confirm new password

                        </label>

                        <div class="password-wrapper">

                            <input id="confirmPassword"
                                   name="confirmPassword"
                                   type="password"
                                   class="form-control password-input"
                                   placeholder="Confirm new password"
                                   minlength="6"
                                   autocomplete="new-password"
                                   required />

                            <button type="button"
                                    class="password-toggle"
                                    onclick="togglePassword('confirmPassword', this)">

                                <i class="bi bi-eye"></i>

                            </button>

                        </div>

                        <div id="passwordMatch"
                             class="password-help">
                            Enter the same password again.
                        </div>

                    </div>


                    <button type="submit"
                            id="resetBtn"
                            class="btn reset-btn w-100">

                        <i class="bi bi-check2-circle me-2"></i>

                        Reset password

                    </button>

                </form>


                @if (ViewBag.Error != null)
                {
                    <div class="error-message">

                        <i class="bi bi-exclamation-circle me-2"></i>

                        @ViewBag.Error

                    </div>
                }

            </div>


            <div class="security-info">

                <i class="bi bi-shield-check me-1"></i>

                Your password reset is securely processed by TaskFlow

            </div>

        </div>

    </main>


    <script>

            function togglePassword(inputId, button) {

                const input =
                    document.getElementById(inputId);

                const icon =
                    button.querySelector("i");

                if (input.type === "password") {

                    input.type = "text";

                    icon.className =
                        "bi bi-eye-slash";

                }
                else {

                    input.type = "password";

                    icon.className =
                        "bi bi-eye";

                }

            }


            const password =
                document.getElementById("password");

            const confirmPassword =
                document.getElementById("confirmPassword");

            const passwordMatch =
                document.getElementById("passwordMatch");


            function checkPasswords() {

                if (confirmPassword.value.length === 0) {

                    passwordMatch.textContent =
                        "Enter the same password again.";

                    passwordMatch.style.color =
                        "#9ca3af";

                    return;

                }

                if (password.value === confirmPassword.value) {

                    passwordMatch.textContent =
                        "Passwords match.";

                    passwordMatch.style.color =
                        "#059669";

                }
                else {

                    passwordMatch.textContent =
                        "Passwords do not match.";

                    passwordMatch.style.color =
                        "#dc2626";

                }

            }


            password.addEventListener(
                "input",
                checkPasswords
            );

            confirmPassword.addEventListener(
                "input",
                checkPasswords
            );


            document.getElementById("resetPasswordForm")
                .addEventListener("submit", function (event) {

                    if (password.value !== confirmPassword.value) {

                        event.preventDefault();

                        passwordMatch.textContent =
                            "Passwords do not match.";

                        passwordMatch.style.color =
                            "#dc2626";

                        return;

                    }

                    const button =
                        document.getElementById("resetBtn");

                    button.disabled = true;

                    button.innerHTML = `
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        Resetting password...
                    `;

                });

    </script>

</body>

</html>