@model TaskFlow.Models.Project

@{
    ViewData["Title"] = Model.Name;
    var totalTasks = Model.Tasks.Count;
    var completedTasks = Model.Tasks.Count(t => t.Status == "Done");
    var pendingTasks = totalTasks - completedTasks;
    var progress = totalTasks == 0 ? 0 : (int)Math.Round(completedTasks * 100.0 / totalTasks);
}

<style>
    .project-details-page { padding: 42px 0 70px; }
    .project-hero { padding: 28px; background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; }
    .project-name { color: #111827; font-size: clamp(30px, 4vw, 44px); font-weight: 800; letter-spacing: -1.5px; }
    .project-description { max-width: 720px; color: #6b7280; line-height: 1.7; }
    .stat-card { height: 100%; padding: 20px; background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; }
    .stat-value { color: #111827; font-size: 28px; font-weight: 800; }
    .task-card { padding: 20px; background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; }
    .task-title { color: #111827; font-size: 17px; font-weight: 700; }
    .task-description { color: #6b7280; font-size: 14px; line-height: 1.6; }
    .empty-project-tasks { padding: 55px 24px; text-align: center; background: #fff; border: 1px dashed #d1d5db; border-radius: 14px; }
    @@media (max-width: 576px) { .project-details-page { padding-top: 24px; } .project-hero { padding: 22px; } .task-actions { width: 100%; } .task-actions .btn, .task-actions form { flex: 1; } .task-actions form .btn { width: 100%; } }
</style>

<div class="project-details-page">
    <a asp-action="Index" class="text-decoration-none text-muted small">
        <i class="bi bi-arrow-left me-2"></i>Back to projects
    </a>

    <section class="project-hero mt-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-4">
            <div>
                <h1 class="project-name mb-2">@Model.Name</h1>
                <p class="project-description mb-0">@(string.IsNullOrWhiteSpace(Model.Description) ? "No project description." : Model.Description)</p>
            </div>

            <a asp-controller="Task" asp-action="Create" asp-route-projectId="@Model.Id" class="btn btn-primary">
                <i class="bi bi-plus-lg me-2"></i>Add Task
            </a>
        </div>

        <div class="mt-4">
            <div class="d-flex justify-content-between small text-muted mb-2">
                <span>Project progress</span><span>@progress%</span>
            </div>
            <div class="progress"><div class="progress-bar" style="width:@progress%"></div></div>
        </div>
    </section>

    <div class="row g-3 my-3">
        <div class="col-6 col-lg-3"><div class="stat-card"><div class="text-muted small">Total tasks</div><div class="stat-value">@totalTasks</div></div></div>
        <div class="col-6 col-lg-3"><div class="stat-card"><div class="text-muted small">Completed</div><div class="stat-value">@completedTasks</div></div></div>
        <div class="col-6 col-lg-3"><div class="stat-card"><div class="text-muted small">Pending</div><div class="stat-value">@pendingTasks</div></div></div>
        <div class="col-6 col-lg-3"><div class="stat-card"><div class="text-muted small">Deadline</div><div class="fw-bold mt-2">@Model.Deadline.ToString("dd MMM yyyy")</div></div></div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-5 mb-3">
        <h2 class="h4 fw-bold mb-0">Project tasks</h2>
    </div>

    @if (!Model.Tasks.Any())
    {
        <div class="empty-project-tasks">
            <i class="bi bi-check2-square fs-2 text-primary"></i>
            <h3 class="h5 fw-bold mt-3">No tasks yet</h3>
            <p class="text-muted">Add the first task to start tracking this project.</p>
            <a asp-controller="Task" asp-action="Create" asp-route-projectId="@Model.Id" class="btn btn-primary">Add Task</a>
        </div>
    }
    else
    {
        <div class="d-grid gap-3">
            @foreach (var task in Model.Tasks.OrderBy(t => t.Status == "Done").ThenBy(t => t.DueDate))
            {
                <article class="task-card">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                        <div class="flex-grow-1">
                            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                <span class="task-title">@task.Title</span>
                                <span class="badge @(task.Status == "Done" ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning-emphasis")">@task.Status</span>
                                <span class="badge bg-light text-dark">@task.Priority</span>
                            </div>
                            <p class="task-description mb-2">@(string.IsNullOrWhiteSpace(task.Description) ? "No description." : task.Description)</p>
                            <small class="text-muted"><i class="bi bi-calendar3 me-1"></i>Due @task.DueDate.ToString("dd MMM yyyy")</small>
                        </div>

                        <div class="d-flex flex-wrap gap-2 task-actions">
                            @if (task.Status != "Done")
                            {
                                <form asp-action="CompleteTask" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <button class="btn btn-outline-success btn-sm">Complete</button>
                                </form>
                            }
                            <a asp-action="EditTask" asp-route-id="@task.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                            <form asp-action="DeleteTask" method="post" onsubmit="return confirm('Delete this task?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@task.Id" />
                                <button class="btn btn-outline-danger btn-sm">Delete</button>
                            </form>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</div>
