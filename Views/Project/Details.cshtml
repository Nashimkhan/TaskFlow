@using Microsoft.AspNetCore.Identity
@model TaskFlow.Models.Project

@{
    ViewData["Title"] = Model.Name;

    var users = ViewBag.Users as Dictionary<string, string>
        ?? new Dictionary<string, string>();

    var isOwner = ViewBag.IsOwner == true;

    var totalTasks = Model.Tasks.Count;

    var completedTasks =
        Model.Tasks.Count(t => t.Status == "Done");

    var progress =
        totalTasks == 0
            ? 0
            : (int)Math.Round(
                completedTasks * 100.0 / totalTasks);

    var acceptedMembers =
        Model.Members
            .Where(x => x.Status == "Accepted")
            .ToList();

    var pendingMembers =
        Model.Members
            .Where(x => x.Status == "Pending")
            .ToList();

    var currentUserId =
        User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="page">

    <div class="container">

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 page-header">

            <div>

                <a asp-action="Index"
                   class="btn btn-light mb-3">

                    <i class="bi bi-arrow-left me-2"></i>

                    Back

                </a>

                <h1 class="page-title">

                    @Model.Name

                </h1>

                <p class="page-subtitle">

                    @(string.IsNullOrWhiteSpace(Model.Description)
                        ? "No description available."
                        : Model.Description)

                </p>

            </div>

            <div class="text-end">

                <h2 class="fw-bold">

                    @progress%

                </h2>

                <small class="text-muted">

                    Completed

                </small>

            </div>

        </div>

        <div class="card mb-4">

            <div class="card-body">

                <div class="row align-items-center">

                    <div class="col-lg-9">

                        <div class="progress mb-3">

                            <div class="progress-bar"
                                 style="width:@progress%">
                            </div>

                        </div>

                        <div class="d-flex gap-4 flex-wrap text-muted">

                            <span>

                                <i class="bi bi-check2-square me-2"></i>

                                @completedTasks / @totalTasks Tasks

                            </span>

                            <span>

                                <i class="bi bi-calendar3 me-2"></i>

                                @Model.Deadline.ToString("dd MMM yyyy")

                            </span>

                            <span>

                                <i class="bi bi-people me-2"></i>

                                @(acceptedMembers.Count + 1) Members

                            </span>

                        </div>

                    </div>

                    <div class="col-lg-3 text-lg-end mt-3 mt-lg-0">

                        @if (isOwner)
                        {
                            <a asp-controller="Task"
                               asp-action="Create"
                               asp-route-projectId="@Model.Id"
                               class="btn btn-primary">

                                <i class="bi bi-plus-lg me-2"></i>

                                New Task

                            </a>
                        }

                    </div>

                </div>

            </div>

        </div>

        <div class="row">

            <div class="col-lg-8">

                               <div class="card">

    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h3 class="section-title">

                    Project Tasks

                </h3>

                <small class="text-muted">

                    @completedTasks of @totalTasks completed

                </small>

            </div>

            @if (isOwner)
            {
                <a asp-action="AiBreakdown"
                   asp-controller="Task"
                   asp-route-projectId="@Model.Id"
                   class="btn btn-outline-primary">

                    <i class="bi bi-stars me-2"></i>

                    AI Breakdown

                </a>
            }

        </div>

        @if (!Model.Tasks.Any())
        {

            <div class="empty-state">

                <i class="bi bi-list-task"></i>

                <h3>

                    No Tasks Yet

                </h3>

                <p>

                    Create your first project task.

                </p>

            </div>

        }
        else
        {

            @foreach (var task in Model.Tasks.OrderBy(x => x.DueDate))
            {

                var assignedUser =
                    string.IsNullOrWhiteSpace(task.AssignedUserId)
                    ? null
                    : users.TryGetValue(task.AssignedUserId, out var username)
                        ? username
                        : "Unknown User";

                var statusClass =
                    task.Status == "Done"
                        ? "status-done"
                        : "status-pending";

                var priorityClass =
                    task.Priority == "High"
                        ? "priority-high"
                        : task.Priority == "Medium"
                            ? "priority-medium"
                            : "priority-low";

                <div class="task-card">

                    <div class="d-flex justify-content-between align-items-start mb-3">

                        <div>

                            <h5 class="task-title">

                                @task.Title

                            </h5>

                            <p class="task-description mb-0">

                                @(string.IsNullOrWhiteSpace(task.Description)
                                    ? "No description available."
                                    : task.Description)

                            </p>

                        </div>

                        <span class="badge @statusClass">

                            @task.Status

                        </span>

                    </div>

                    <div class="row g-3">

                        <div class="col-md-4">

                            <small class="text-muted">

                                Priority

                            </small>

                            <br />

                            <span class="badge @priorityClass">

                                @task.Priority

                            </span>

                        </div>

                        <div class="col-md-4">

                            <small class="text-muted">

                                Due Date

                            </small>

                            <br />

                            <strong>

                                @task.DueDate.ToString("dd MMM yyyy")

                            </strong>

                        </div>

                        <div class="col-md-4">

                            <small class="text-muted">

                                Assigned To

                            </small>

                            <br />

                            @if (assignedUser == null)
                            {
                                <span class="badge bg-danger">

                                    Unassigned

                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">

                                    @assignedUser

                                </span>
                            }

                        </div>

                    </div>
                                    <div class="d-flex justify-content-between align-items-center mt-4">

                                        <div>

                                            @if (task.Status == "Done")
                                            {
                                                <span class="badge bg-success">

                                                    <i class="bi bi-check-circle me-1"></i>

                                                    Completed

                                                </span>
                                            }
                                            else if (string.IsNullOrWhiteSpace(task.AssignedUserId))
                                            {
                                                <span class="badge bg-secondary">

                                                    <i class="bi bi-hourglass-split me-1"></i>

                                                    Waiting for Assignment

                                                </span>
                                            }
                                            else if (task.AssignedUserId == currentUserId)
                                            {
                                                <form asp-action="CompleteTask"
                                                      method="post"
                                                      class="d-inline">

                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden"
                                                           name="id"
                                                           value="@task.Id" />

                                                    <button class="btn btn-success btn-sm">

                                                        <i class="bi bi-check2 me-1"></i>

                                                        Mark Complete

                                                    </button>

                                                </form>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">

                                                    <i class="bi bi-person-check me-1"></i>

                                                    Assigned to another member

                                                </span>
                                            }

                                        </div>

                                        @if (isOwner)
                                        {

                                            <div class="d-flex gap-2">

                                                <a asp-action="EditTask"
                                                   asp-route-id="@task.Id"
                                                   class="btn btn-outline-primary btn-sm">

                                                    <i class="bi bi-pencil me-1"></i>

                                                    Edit

                                                </a>

                                                <form asp-action="DeleteTask"
                                                      method="post"
                                                      onsubmit="return confirm('Delete this task?');">

                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden"
                                                           name="id"
                                                           value="@task.Id" />

                                                    <button class="btn btn-outline-danger btn-sm">

                                                        <i class="bi bi-trash me-1"></i>

                                                        Delete

                                                    </button>

                                                </form>

                                            </div>

                                        }

                                    </div>

                                </div>

                            }

                        }

                    </div>

                </div>

            </div>

            <div class="col-lg-4">
                @if (isOwner)
{

    <div class="card mb-4">

        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <h3 class="section-title mb-0">

                    Team

                </h3>

                <span class="badge bg-primary">

                    @(acceptedMembers.Count + 1)

                </span>

            </div>

            @{
                var ownerName =
                    users.TryGetValue(Model.OwnerId, out var owner)
                        ? owner
                        : "Owner";
            }

            <div class="member">

                <div class="member-info">

                    <div class="member-avatar">

                        @ownerName.Substring(0,1).ToUpper()

                    </div>

                    <div>

                        <div class="member-name">

                            @ownerName

                        </div>

                        <small class="text-muted">

                            Owner

                        </small>

                    </div>

                </div>

            </div>

            @foreach (var member in acceptedMembers)
            {

                var memberName =
                    users.TryGetValue(member.UserId, out var name)
                        ? name
                        : "Unknown User";

                <div class="member">

                    <div class="member-info">

                        <div class="member-avatar">

                            @memberName.Substring(0,1).ToUpper()

                        </div>

                        <div>

                            <div class="member-name">

                                @memberName

                            </div>

                            <small class="text-muted">

                                Team Member

                            </small>

                        </div>

                    </div>

                    <form asp-action="RemoveMember"
                          method="post"
                          onsubmit="return confirm('Remove this member?');">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="projectId"
                               value="@Model.Id"/>

                        <input type="hidden"
                               name="memberId"
                               value="@member.Id"/>

                        <button class="btn btn-outline-danger btn-sm">

                            Remove

                        </button>

                    </form>

                </div>

            }

        </div>

    </div>

    <div class="card mb-4">

        <div class="card-body">

            <h3 class="section-title mb-4">

                Pending Invitations

            </h3>

            @if (!pendingMembers.Any())
            {

                <div class="text-muted">

                    No pending invitations.

                </div>

            }
            else
            {

                @foreach (var member in pendingMembers)
                {

                    var memberName =
                        users.TryGetValue(member.UserId, out var name)
                            ? name
                            : "Unknown User";

                    <div class="member">

                        <div class="member-info">

                            <div class="member-avatar">

                                @memberName.Substring(0,1).ToUpper()

                            </div>

                            <div>

                                <div class="member-name">

                                    @memberName

                                </div>

                                <small class="text-warning">

                                    Pending

                                </small>

                            </div>

                        </div>

                        <form asp-action="CancelInvitation"
                              method="post">

                            @Html.AntiForgeryToken()

                            <input type="hidden"
                                   name="projectId"
                                   value="@Model.Id"/>

                            <input type="hidden"
                                   name="memberId"
                                   value="@member.Id"/>

                            <button class="btn btn-outline-warning btn-sm">

                                Cancel

                            </button>

                        </form>

                    </div>

                }

            }

        </div>

    </div>

    <div class="card">

        <div class="card-body">

            <h3 class="section-title mb-3">

                Invite Member

            </h3>

            <form asp-action="Invite"
                  method="post">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="projectId"
                       value="@Model.Id"/>

                <input class="form-control mb-3"
                       name="userSearch"
                       placeholder="Username or Email"
                       required/>

                <button class="btn btn-primary w-100">

                    <i class="bi bi-person-plus me-2"></i>

                    Send Invitation

                </button>

            </form>

        </div>

    </div>

}
else
{

    <div class="card">

        <div class="card-body">

            <h3 class="section-title mb-4">

                Team Members

            </h3>

            @{
                var ownerName =
                    users.TryGetValue(Model.OwnerId, out var owner)
                        ? owner
                        : "Owner";
            }

            <div class="member">

                <div class="member-info">

                    <div class="member-avatar">

                        @ownerName.Substring(0,1).ToUpper()

                    </div>

                    <div>

                        <div class="member-name">

                            @ownerName

                        </div>

                        <small class="text-muted">

                            Project Owner

                        </small>

                    </div>

                </div>

            </div>

                            @foreach (var member in acceptedMembers)
                            {
                                var memberName =
                                    users.TryGetValue(member.UserId, out var name)
                                        ? name
                                        : "Unknown User";

                                <div class="member">

                                    <div class="member-info">

                                        <div class="member-avatar">

                                            @memberName.Substring(0,1).ToUpper()

                                        </div>

                                        <div>

                                            <div class="member-name">

                                                @memberName

                                            </div>

                                            @if (member.UserId == currentUserId)
                                            {
                                                <small class="text-primary">

                                                    You

                                                </small>
                                            }
                                            else
                                            {
                                                <small class="text-muted">

                                                    Team Member

                                                </small>
                                            }

                                        </div>

                                    </div>

                                </div>

                            }

                        </div>

                    </div>

                }

            </div>

        </div>

    </div>
