@model List<TaskFlow.Models.Project>

@{
    ViewData["Title"] = "Projects";
}

<div class="page">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 page-header">
            <div>
                <h1 class="page-title">Projects</h1>
                <p class="page-subtitle">Organize related tasks and track progress in one place.</p>
            </div>

            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-2"></i>New Project
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-folder2-open"></i>
                <h3>No projects yet</h3>
                <p>Create a project to group tasks and track your progress.</p>
                <a asp-action="Create" class="btn btn-primary mt-3">Create Project</a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var project in Model)
                {
                    var totalTasks = project.Tasks.Count;
                    var completedTasks = project.Tasks.Count(t => t.Status == "Done");
                    var progress = totalTasks == 0 ? 0 : (int)Math.Round(completedTasks * 100.0 / totalTasks);

                    <div class="col-md-6 col-xl-4">
                        <div class="project-card shadow-soft h-100">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h4 class="project-title mb-0">@project.Name</h4>
                                <span class="badge bg-light text-dark">@progress%</span>
                            </div>

                            <p class="project-description">
                                @(string.IsNullOrWhiteSpace(project.Description) ? "No description available." : project.Description)
                            </p>

                            <div class="progress mb-4">
                                <div class="progress-bar" style="width:@progress%"></div>
                            </div>

                            <div class="d-flex justify-content-between text-muted small mb-4">
                                <span><i class="bi bi-check2-square me-1"></i>@completedTasks / @totalTasks Tasks</span>
                                <span><i class="bi bi-calendar3 me-1"></i>@project.Deadline.ToString("dd MMM yyyy")</span>
                            </div>

                            <a asp-action="Details" asp-route-id="@project.Id" class="btn btn-outline-primary btn-sm w-100">Open Project</a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
