@model List<TaskFlow.Models.ProjectMember>

@{
    ViewData["Title"] = "Project Invitations";
}

<div class="page">

    <div class="container" style="max-width:900px;">

        <div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-3">

            <div>

                <h1 class="page-title">

                    Project Invitations

                </h1>

                <p class="page-subtitle">

                    Accept or decline invitations to collaborate.

                </p>

            </div>

            <a asp-action="Index"
               class="btn btn-light">

                <i class="bi bi-arrow-left me-2"></i>

                Back

            </a>

        </div>

        @if (!Model.Any())
        {

            <div class="empty-state">

                <i class="bi bi-inbox"></i>

                <h3>

                    No Invitations

                </h3>

                <p>

                    You don't have any pending invitations.

                </p>

            </div>

        }
        else
        {

            @foreach (var invitation in Model)
            {

                <div class="project-card mb-3">

                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-4">

                        <div class="flex-grow-1">

                            <h4 class="project-title mb-2">

                                @invitation.Project.Name

                            </h4>

                            <p class="project-description mb-3">

                                @(string.IsNullOrWhiteSpace(invitation.Project.Description)
                                    ? "You have been invited to collaborate on this project."
                                    : invitation.Project.Description)

                            </p>

                            <small class="text-muted">

                                <i class="bi bi-calendar3 me-2"></i>

                                Deadline:

                                @invitation.Project.Deadline.ToString("dd MMM yyyy")

                            </small>

                        </div>

                        <div class="d-flex gap-2">

                            <form asp-action="RejectInvitation"
                                  method="post">

                                @Html.AntiForgeryToken()

                                <input type="hidden"
                                       name="id"
                                       value="@invitation.Id" />

                                <button class="btn btn-outline-danger">

                                    Decline

                                </button>

                            </form>

                            <form asp-action="AcceptInvitation"
                                  method="post">

                                @Html.AntiForgeryToken()

                                <input type="hidden"
                                       name="id"
                                       value="@invitation.Id" />

                                <button class="btn btn-primary">

                                    <i class="bi bi-check2 me-2"></i>

                                    Accept

                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            }

        }

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}