@model TaskFlow.Models.Project

@{
    ViewData["Title"] = "Create Project";
}

<div class="page">

    <div class="container" style="max-width:760px;">

        <div class="page-header">

            <a asp-action="Index"
               class="btn btn-light mb-3">

                <i class="bi bi-arrow-left me-2"></i>

                Back

            </a>

            <h1 class="page-title">

                Create Project

            </h1>

            <p class="page-subtitle">

                Create a workspace to organize tasks and collaborate with your team.

            </p>

        </div>

        <div class="card">

            <div class="card-body">

                <form asp-action="Create"
                      method="post">

                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3"></div>

                    <div class="mb-4">

                        <label asp-for="Name"
                               class="form-label">

                            Project Name

                        </label>

                        <input asp-for="Name"
                               class="form-control"
                               placeholder="E-Commerce Website" />

                        <span asp-validation-for="Name"
                              class="text-danger"></span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Description"
                               class="form-label">

                            Description

                        </label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  placeholder="Describe your project..."></textarea>

                        <span asp-validation-for="Description"
                              class="text-danger"></span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Deadline"
                               class="form-label">

                            Deadline

                        </label>

                        <input asp-for="Deadline"
                               type="date"
                               class="form-control" />

                        <span asp-validation-for="Deadline"
                              class="text-danger"></span>

                    </div>

                    <div class="d-flex justify-content-end gap-2">

                        <a asp-action="Index"
                           class="btn btn-light">

                            Cancel

                        </a>

                        <button class="btn btn-primary">

                            <i class="bi bi-folder-plus me-2"></i>

                            Create Project

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}